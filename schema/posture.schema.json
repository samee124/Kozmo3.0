{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kozmo.posture.v1",
  "title": "PostureAssignment",
  "description": "Deterministic stance assignment for an entity, derived from band + pattern + renewal proximity.",
  "type": "object",
  "required": ["id", "entity_id", "band", "stance", "rationale", "evidence_trail", "confidence", "fingerprint", "index_version", "assigned_at"],
  "properties": {
    "id":            { "type": "string", "format": "uuid" },
    "entity_id":     { "type": "string", "format": "uuid" },
    "band":          { "$ref": "#/$defs/Band" },
    "stance":        { "$ref": "#/$defs/Stance" },
    "rationale":     { "type": "string" },
    "evidence_trail": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "confidence":      { "type": "number", "minimum": 0, "maximum": 1 },
    "fingerprint":     { "type": "string" },
    "index_version":   { "type": "integer", "minimum": 1 },
    "assigned_at":     { "type": "string", "format": "date-time" },
    "valid_until":     { "type": "string", "format": "date-time", "nullable": true }
  },
  "$defs": {
    "Band":   { "enum": ["Healthy", "AtRisk", "Critical"] },
    "Stance": { "enum": ["Maintain", "Monitor", "Renegotiate", "Escalate", "Remediate"] }
  }
}
