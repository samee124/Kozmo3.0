{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kozmo.signal.v1",
  "title": "Signal",
  "description": "Raw observation from an external source system before classification.",
  "type": "object",
  "required": ["id", "entity_id", "customer_id", "source_system", "external_id", "payload", "observed_at", "received_at", "trace_id"],
  "properties": {
    "id":            { "type": "string", "format": "uuid" },
    "entity_id":     { "type": "string", "format": "uuid" },
    "customer_id":   { "type": "string", "format": "uuid" },
    "source_system": { "$ref": "#/$defs/SourceSystem" },
    "external_id":   { "type": "string" },
    "payload":       { "type": "object", "additionalProperties": true },
    "observed_at":   { "type": "string", "format": "date-time" },
    "received_at":   { "type": "string", "format": "date-time" },
    "trace_id":      { "type": "string", "format": "uuid" }
  },
  "$defs": {
    "SourceSystem": {
      "enum": ["MonitoringPlatform", "BillingSystem", "CRM", "SupportSystem", "UsageAnalytics", "Email", "ContractSystem", "HumanReport"]
    }
  }
}
