{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kozmo.entity_index.v1",
  "title": "EntityIndex",
  "description": "Multi-dimensional health index for one entity: composite score, confidence floor, band, and reproducible fingerprint.",
  "type": "object",
  "required": ["entity_id", "dimension_scores", "composite", "confidence_floor", "band", "fingerprint", "version", "computed_at"],
  "properties": {
    "entity_id":        { "type": "string", "format": "uuid" },
    "dimension_scores": {
      "type": "object",
      "properties": {
        "Operational":  { "$ref": "#/$defs/DimensionScore" },
        "Experiential": { "$ref": "#/$defs/DimensionScore" },
        "Financial":    { "$ref": "#/$defs/DimensionScore" },
        "Strategic":    { "$ref": "#/$defs/DimensionScore" }
      }
    },
    "composite":         { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence_floor":  { "type": "number", "minimum": 0, "maximum": 1 },
    "band":              { "$ref": "#/$defs/Band" },
    "fingerprint":       { "type": "string", "description": "Hex-encoded SHA-256 of sorted beliefs ⊕ dimension scores ⊕ weights ⊕ config_version" },
    "version":           { "type": "integer", "minimum": 1 },
    "computed_at":       { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "Band": { "enum": ["Healthy", "AtRisk", "Critical"] },
    "DimensionScore": {
      "type": "object",
      "required": ["score", "confidence"],
      "properties": {
        "score":      { "type": "number", "minimum": 0, "maximum": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
