@page
@{
    Layout = null;
}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Kozmo · Sign in</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
a{color:inherit;text-decoration:none}
button{font:inherit;cursor:pointer;border:0;background:transparent;color:inherit;padding:0}
input{font:inherit}

@@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
@@keyframes pulse{0%,100%{opacity:1}50%{opacity:.45}}
@@keyframes shimmer{0%{opacity:.7}50%{opacity:1}100%{opacity:.7}}

/* ══════════════════ SHELL ══════════════════ */
.shell{display:flex;height:100vh;overflow:hidden}

/* ══════════════════ LEFT ══════════════════ */
.lp{
  width:56%;
  background:linear-gradient(145deg,#EEF2FF 0%,#F0E6FF 48%,#E8F4FE 100%);
  display:flex;flex-direction:column;justify-content:center;
  padding:64px 68px;position:relative;overflow:hidden;
}
.lp-blob{
  position:absolute;border-radius:50%;filter:blur(70px);
  pointer-events:none;
}
.lp-blob-1{width:320px;height:320px;background:#C7D2FE;opacity:.3;right:-90px;top:-90px}
.lp-blob-2{width:220px;height:220px;background:#DDD6FE;opacity:.25;left:-70px;bottom:40px}

/* Brand row */
.brand-row{
  display:flex;align-items:center;gap:8px;
  margin-bottom:40px;
  animation:fadeUp .4s ease both;
}
.brand-dot{
  width:7px;height:7px;border-radius:50%;background:#4F46E5;
  animation:pulse 3s ease infinite;
}
.brand-lbl{
  font-size:10.5px;font-weight:700;letter-spacing:.13em;
  text-transform:uppercase;color:#6B7280;
}

/* Hero */
.hero{max-width:460px;margin-bottom:22px;animation:fadeUp .4s ease .05s both}
.hero-line1{font-size:30px;font-weight:400;color:#111827;line-height:1.35}
.hero-accent{font-size:30px;font-weight:700;color:#3730A3;line-height:1.35}

/* Compliance */
.compliance{
  font-size:11.5px;color:#9CA3AF;letter-spacing:.01em;
  margin-bottom:52px;
  animation:fadeUp .4s ease .1s both;
}

/* Agent cards */
.agent-stack{display:flex;flex-direction:column;gap:0}
.a-card{
  background:#FFFFFF;border-radius:12px;padding:16px 20px;
  box-shadow:0 2px 14px rgba(79,70,229,.08),0 1px 3px rgba(0,0,0,.06);
  max-width:390px;animation:fadeUp .45s ease both;
}
.a-card:nth-child(1){margin-left:0;margin-bottom:10px;animation-delay:.15s}
.a-card:nth-child(2){margin-left:52px;margin-bottom:10px;animation-delay:.25s}
.a-card:nth-child(3){margin-left:104px;animation-delay:.35s}
.a-label{
  font-size:10px;font-weight:700;letter-spacing:.1em;
  text-transform:uppercase;color:#4573D2;margin-bottom:6px;
}
.a-body{font-size:13px;color:#374151;line-height:1.55}
.a-body strong{font-weight:600;color:#111827}

/* ══════════════════ RIGHT ══════════════════ */
.rp{
  flex:1;background:#FFFFFF;
  display:flex;flex-direction:column;justify-content:center;
  padding:60px 72px;overflow-y:auto;
}

/* Tabs */
.tab-row{
  display:flex;align-items:center;gap:3px;
  background:#F3F4F6;border-radius:999px;padding:3px;
  width:fit-content;margin-bottom:44px;
  animation:fadeUp .35s ease .05s both;
}
.tab-btn{
  font-size:13px;font-weight:500;
  padding:7px 20px;border-radius:999px;
  color:#6B7280;transition:all .14s ease;
  white-space:nowrap;
}
.tab-btn.on{
  background:#FFFFFF;color:#111827;font-weight:600;
  box-shadow:0 1px 3px rgba(0,0,0,.1),0 1px 2px rgba(0,0,0,.06);
}
.tab-btn:hover:not(.on){color:#374151}

/* Welcome */
.welcome-title{
  font-size:34px;font-weight:700;color:#111827;
  letter-spacing:-.025em;margin-bottom:8px;
  animation:fadeUp .35s ease .1s both;
}
.welcome-sub{
  font-size:14px;color:#6B7280;line-height:1.6;
  margin-bottom:34px;
  animation:fadeUp .35s ease .15s both;
}

/* Providers */
.providers{
  display:flex;flex-direction:column;gap:10px;
  margin-bottom:28px;
  animation:fadeUp .35s ease .2s both;
}
.prov-row{
  display:flex;align-items:center;gap:14px;
  padding:13px 18px;border-radius:10px;
  border:1px solid #E5E7EB;background:#FFFFFF;
  transition:background .12s,border-color .12s,box-shadow .12s;
  cursor:pointer;
}
.prov-row:hover{background:#F9FAFB;border-color:#D1D5DB;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.prov-ico{
  width:20px;height:20px;display:flex;align-items:center;
  justify-content:center;flex-shrink:0;color:#6B7280;
}
.prov-name{font-size:14px;color:#374151;font-weight:400;flex:1}
.prov-tag{
  font-size:11px;color:#9CA3AF;font-weight:600;
  letter-spacing:.04em;flex-shrink:0;
}

/* Divider */
.or-div{
  display:flex;align-items:center;gap:12px;
  margin-bottom:24px;
  animation:fadeUp .35s ease .25s both;
}
.or-line{flex:1;height:1px;background:#E5E7EB}
.or-lbl{
  font-size:11px;font-weight:600;letter-spacing:.1em;
  text-transform:uppercase;color:#9CA3AF;white-space:nowrap;
}

/* Form */
.form-block{animation:fadeUp .35s ease .3s both}
.field{margin-bottom:16px}
.field-lbl{
  display:block;font-size:11px;font-weight:600;
  letter-spacing:.08em;text-transform:uppercase;
  color:#6B7280;margin-bottom:8px;
}
.field-inp{
  width:100%;padding:10px 14px;
  background:#F9FAFB;border:1px solid #E5E7EB;border-radius:8px;
  font-size:14px;color:#111827;outline:none;
  transition:border-color .12s,background .12s,box-shadow .12s;
}
.field-inp:focus{
  border-color:#4F46E5;background:#FFFFFF;
  box-shadow:0 0 0 3px rgba(79,70,229,.12);
}
.field-inp::placeholder{color:#9CA3AF}
.field-hint{font-size:12px;color:#9CA3AF;margin-top:6px}

/* Footer */
.form-foot{
  display:flex;align-items:center;justify-content:space-between;
  margin-top:26px;
}
.help-lnk{font-size:13px;color:#6B7280}
.btn-continue{
  display:inline-flex;align-items:center;gap:10px;
  background:#312E81;color:#FFFFFF;
  padding:11px 26px;border-radius:8px;
  font-size:14px;font-weight:600;
  transition:background .14s;cursor:pointer;
}
.btn-continue:hover{background:#1E1B4B}
.btn-arrow{font-size:16px;line-height:1}
</style>
</head>
<body>
<div class="shell">

  <!-- ══ LEFT PANEL ══ -->
  <div class="lp">
    <div class="lp-blob lp-blob-1"></div>
    <div class="lp-blob lp-blob-2"></div>

    <div class="brand-row">
      <span class="brand-dot"></span>
      <span class="brand-lbl">Kozmo &middot; Commercial Workspace</span>
    </div>

    <div class="hero">
      <p class="hero-line1">An agent-native commercial<br>operating environment for</p>
      <p class="hero-accent">contracts, vendors, and the<br>decisions between them.</p>
    </div>

    <p class="compliance">SOC 2 Type II &middot; ISO 27001 &middot; GDPR &middot; regional residency</p>

    <div class="agent-stack">
      <div class="a-card">
        <div class="a-label">Intake Agent</div>
        <div class="a-body">Reading <strong>Cloudwave MSA &middot; 2024-09-01.pdf</strong> &middot; 142 pages</div>
      </div>
      <div class="a-card">
        <div class="a-label">Document Manager</div>
        <div class="a-body">Classified <strong>13 signals</strong> across 4 dimensions &middot; 96% confidence</div>
      </div>
      <div class="a-card">
        <div class="a-label">Commercial Manager</div>
        <div class="a-body">3 vendors analyzed &middot; renewal pressure detected</div>
      </div>
    </div>
  </div>

  <!-- ══ RIGHT PANEL ══ -->
  <div class="rp">

    <div class="tab-row">
      <button class="tab-btn on" type="button">Sign in</button>
      <button class="tab-btn" type="button">Create account</button>
      <button class="tab-btn" type="button">Accept invite</button>
    </div>

    <h1 class="welcome-title">Welcome back.</h1>
    <p class="welcome-sub">Continue with your enterprise identity provider, or use email.</p>

    <div class="providers">
      <!-- SSO — decorative -->
      <div class="prov-row">
        <span class="prov-ico">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </span>
        <span class="prov-name">Continue with SSO (SAML / OIDC)</span>
        <span class="prov-tag">ENTERPRISE</span>
      </div>
      <!-- Microsoft — decorative -->
      <div class="prov-row">
        <span class="prov-ico">
          <svg width="16" height="16" viewBox="0 0 21 21" aria-hidden="true">
            <rect width="10" height="10" fill="#F25022"/>
            <rect x="11" width="10" height="10" fill="#7FBA00"/>
            <rect y="11" width="10" height="10" fill="#00A4EF"/>
            <rect x="11" y="11" width="10" height="10" fill="#FFB900"/>
          </svg>
        </span>
        <span class="prov-name">Continue with Microsoft Entra</span>
      </div>
      <!-- Google — FUNCTIONAL -->
      <a href="/auth/google" class="prov-row" style="border-color:#4573D2;background:#F5F8FF">
        <span class="prov-ico">
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
        </span>
        <span class="prov-name" style="color:#3730A3;font-weight:500">Continue with Google Workspace</span>
      </a>
      <!-- Okta — decorative -->
      <div class="prov-row">
        <span class="prov-ico">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="9"/>
            <circle cx="12" cy="12" r="3.5"/>
          </svg>
        </span>
        <span class="prov-name">Okta &middot; Azure AD &middot; Auth0</span>
        <span class="prov-tag">SAML</span>
      </div>
    </div>

    <div class="or-div">
      <div class="or-line"></div>
      <span class="or-lbl">Or with email</span>
      <div class="or-line"></div>
    </div>

    <div class="form-block">
      <div class="field">
        <label class="field-lbl" for="work-email">Work Email</label>
        <input class="field-inp" id="work-email" type="email"
               placeholder="you@company.com" autocomplete="email"/>
      </div>
      <div class="field">
        <label class="field-lbl" for="password">Password</label>
        <input class="field-inp" id="password" type="password"
               placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;" autocomplete="current-password"/>
        <p class="field-hint">Or we can email you a one-time code.</p>
      </div>
      <div class="form-foot">
        <span class="help-lnk">Need help signing in?</span>
        <a href="/auth/google" class="btn-continue">
          Continue <span class="btn-arrow">&#8594;</span>
        </a>
      </div>
    </div>

  </div>
</div>
</body>
</html>
