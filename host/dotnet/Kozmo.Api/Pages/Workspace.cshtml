          <div class="tab-panel on" id="panel-ingest">
            <div class="ingest-panel">

              <!-- Drive connection card -->
              <div class="drive-card disc" id="drive-card">
                <div class="drive-card-hdr">
                  <div class="drive-card-ico disc" id="drive-ico">
                    <svg style="width:22px;height:22px" viewBox="0 0 87 78"><path d="M6.1 66l4.1 7.1c.9 1.5 2.1 2.7 3.5 3.6L27.5 53H0c0 1.7.4 3.4 1.3 4.9L6.1 66z" fill="#0066DA"/><path d="M43.5 25L29.7 1.3C28.3 2.2 27 3.4 26.1 4.9L1.3 48.1c-.8 1.5-1.3 3.1-1.3 4.9h27.5L43.5 25z" fill="#00AC47"/><path d="M73.3 76.7c1.5-.9 2.7-2.1 3.5-3.6l1.7-2.9 8.2-14.2c.8-1.5 1.3-3.2 1.3-4.9H60.5L73.3 76.7z" fill="#EA4335"/><path d="M43.5 25l13.8-23.7C55.8.4 54.1 0 52.3 0H34.7c-1.8 0-3.5.4-5 1.3L43.5 25z" fill="#00832D"/><path d="M60.5 53H27.5L13.7 76.7c1.5.8 3.2 1.3 5 1.3h47.6c1.8 0 3.5-.4 5-1.3L60.5 53z" fill="#2684FC"/><path d="M73.1 25.5L59.9 2.9C59 1.4 57.8.2 56.3.4L43.5 25 60.5 53h27.4c0-1.7-.4-3.4-1.3-4.9L73.1 25.5z" fill="#FFBA00"/></svg>
                  </div>
                  <div class="drive-card-info">
                    <div class="drive-card-title">Google Drive</div>
                    <div class="drive-card-email" id="drive-email">Not connected — authorize to ingest documents</div>
                  </div>
                  <div class="drive-card-actions">
                    <a href="/auth/google" class="btn-s p" id="btn-connect">
                      <svg class="glyph sm"><use href="#g-link"/></svg>
                      Connect Google Account
                    </a>
                    <button class="btn-s danger" id="btn-disconnect" style="display:none" onclick="disconnectDrive()">
                      Disconnect
                    </button>
                  </div>
                </div>
              </div>

              <!-- Ingestion form -->
              <div class="ingest-form">
                <div class="if-title">Run Ingestion</div>
                <div class="if-sub">
                  Paste a Google Drive folder or file link below. Kozmo will download all supported documents (PDF, Google Docs, Sheets, Slides) and run the full vendor intelligence pipeline.
                </div>
                <div class="if-row">
                  <input type="text" class="if-input" id="drive-url"
                         placeholder="Paste a Drive folder URL or file URL (folders/… or file/d/…)" />
                  <button class="btn-s p" id="btn-run" onclick="runIngestion()" disabled>
                    <svg class="glyph sm"><use href="#g-play"/></svg>
                    Run
                  </button>
                </div>
              </div>

              <!-- Live ingestion log -->
              <div class="log-card">
                <div class="log-hdr">
                  <svg class="glyph sm" style="color:var(--ink-3)"><use href="#g-trend"/></svg>
                  <span class="log-hdr-title">Ingestion Log</span>
                  <div class="log-status idle" id="log-status">
                    <span class="ls-dot"></span>
                    <span id="log-status-text">Idle</span>
                  </div>
                </div>
                <div class="log-body" id="log-body">
                  <div class="log-idle">Waiting for ingestion to start…</div>
                </div>
              </div>

            </div>
          </div>

          <!-- ── VENDORS TAB ── -->
          <div class="tab-panel" id="panel-vendors">
            <div class="vendors-panel">
              <div class="v-hdr">
                <div>
                  <div class="v-title">Vendor Portfolio</div>
                  <div class="v-sub" id="vendor-count">Loading…</div>
                </div>
                <button class="btn-s" onclick="loadVendors()">
                  <svg class="glyph sm"><use href="#g-refresh"/></svg>
                  Refresh
                </button>
              </div>
              <div class="vtbl-wrap">
                <table class="vtbl">
                  <thead>
                    <tr>
                      <th>Vendor</th>
                      <th>Band</th>
                      <th>Stance</th>
                      <th>Confidence</th>
                      <th>As Of</th>
                    </tr>
                  </thead>
                  <tbody id="vendor-tbody">
                    <tr><td colspan="5" style="text-align:center;color:var(--ink-4);padding:var(--s8)">Loading vendors…</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

        </div><!-- /tab-panels -->
      </div><!-- /pv-content -->
    </div><!-- /view-prog -->

  </div><!-- /main -->
</div><!-- /app -->

<!-- ── TWEAKS ── -->
<button class="float-settings" id="float-settings-btn" onclick="tTweaks()" title="Appearance" style="display:none">
  <svg class="glyph sm"><use href="#g-settings"/></svg>
</button>

<div class="tweaks" id="tweaks">
  <div class="tw-h">
    <span class="tw-t">Appearance</span>
    <span class="tw-x" onclick="tTweaks()"><svg class="glyph xs"><use href="#g-x"/></svg></span>
  </div>
  <div class="tw-b">
    <div class="tw-sec">
      <div class="tw-l">Accent Color</div>
      <div class="tw-row" id="tw-accent" style="gap:10px">
        <div class="tw-swatch on" data-accent="coral"   style="background:#F06A6A" title="Coral"></div>
        <div class="tw-swatch"    data-accent="indigo"  style="background:#4573D2" title="Indigo"></div>
        <div class="tw-swatch"    data-accent="emerald" style="background:#14A085" title="Emerald"></div>
        <div class="tw-swatch"    data-accent="violet"  style="background:#6F58D9" title="Violet"></div>
      </div>
    </div>
  </div>
</div>

<script>
// ══════════════════════════════════════════════
//  KOZMO WORKSPACE  —  Client-side logic
// ══════════════════════════════════════════════

var S = {
  screen: 'login',
  email: null,
  connected: false,
  running: false,
  sse: null,
  programName: ''
};

// ─────────────────────────────────────────────
//  SCREEN MANAGEMENT
// ─────────────────────────────────────────────
function show(name) {
  ['login','home','app'].forEach(function(n) {
    document.getElementById('screen-' + n).classList.toggle('hidden', n !== name);
  });
  S.screen = name;
  // Show/hide settings button in app only
  var btn = document.getElementById('float-settings-btn');
  if (btn) btn.style.display = name === 'app' ? 'flex' : 'none';
}

function goHome() {
  show('home');
  stopSse();
}

function enterProgram(id, name) {
  S.programName = name || 'Program';
  var progTitle = document.getElementById('prog-title');
  if (progTitle) progTitle.textContent = name || 'Program';
  var bcProg = document.getElementById('bc-prog');
  if (bcProg) bcProg.textContent = name || 'Program';
  var sbName = document.getElementById('sb-prog-name');
  if (sbName) sbName.textContent = name || 'Program';
  show('app');
  switchTab('ingest', null, true);
  updateDriveCard();
}

function signOut() {
  S.email = null;
  S.connected = false;
  stopSse();
  show('login');
}

// ─────────────────────────────────────────────
//  AUTH CHECK
// ─────────────────────────────────────────────
async function checkAuth() {
  try {
    var r = await fetch('/auth/google/status');
    var d = await r.json();
    S.email = d.email || null;
    S.connected = d.connected && !d.tokenExpired;
    applyUserUI();
    show(d.connected ? 'home' : 'login');
  } catch(e) {
    show('login');
  }
}

function applyUserUI() {
  var e = S.email || '';
  var initials = e ? (e[0] || '?').toUpperCase() : '?';

  // Home
  setTxt('home-email', e);
  setTxt('home-av', initials);
  if (e) {
    var hr = new Date().getHours();
    var greet = hr < 12 ? 'Good morning' : hr < 17 ? 'Good afternoon' : 'Good evening';
    setTxt('home-greeting', greet + ', ' + e.split('@@')[0]);
  }

  // Sidebar / topbar
  setTxt('sb-av', initials);
  setTxt('sb-uname', e || 'User');
  setTxt('top-av', initials);
}

function updateDriveCard() {
  var card     = document.getElementById('drive-card');
  var ico      = document.getElementById('drive-ico');
  var email    = document.getElementById('drive-email');
  var pill     = document.getElementById('drive-pill');
  var pillTxt  = document.getElementById('drive-pill-text');
  var btnConn  = document.getElementById('btn-connect');
  var btnDisc  = document.getElementById('btn-disconnect');
  var btnRun   = document.getElementById('btn-run');

  if (S.connected && S.email) {
    card.className      = 'drive-card conn';
    ico.className       = 'drive-card-ico conn';
    email.textContent   = S.email;
    pill.className      = 'status-pill conn';
    pillTxt.textContent = S.email;
    btnConn.style.display = 'none';
    btnDisc.style.display = 'inline-flex';
    if (btnRun) btnRun.disabled = false;
  } else {
    card.className      = 'drive-card disc';
    ico.className       = 'drive-card-ico disc';
    email.textContent   = 'Not connected — authorize to ingest documents';
    pill.className      = 'status-pill disc';
    pillTxt.textContent = 'Not connected';
    btnConn.style.display = 'inline-flex';
    btnDisc.style.display = 'none';
    if (btnRun) btnRun.disabled = true;
  }
}

function disconnectDrive() {
  S.connected = false;
  S.email = null;
  updateDriveCard();
  applyUserUI();
  show('login');
}

// ─────────────────────────────────────────────
//  TAB SWITCHING
// ─────────────────────────────────────────────
function switchTab(name, triggerEl, silent) {
  document.querySelectorAll('.tab-btn').forEach(function(b) {
    b.classList.toggle('on', b.dataset.tab === name);
  });
  document.querySelectorAll('[data-tab-nav]').forEach(function(n) {
    n.classList.toggle('on', n.dataset.tabNav === name);
  });
  document.querySelectorAll('.tab-panel').forEach(function(p) {
    p.classList.remove('on');
  });
  var panel = document.getElementById('panel-' + name);
  if (panel) panel.classList.add('on');
  if (name === 'vendors' && !silent) loadVendors();
}

// ─────────────────────────────────────────────
//  SIDEBAR COLLAPSE
// ─────────────────────────────────────────────
function toggleSidebar() {
  var sb   = document.getElementById('sb');
  var icon = document.getElementById('col-icon');
  var col  = sb.classList.toggle('col');
  icon.querySelector('use').setAttribute('href', col ? '#g-chev-right' : '#g-chev-left');
}

// ─────────────────────────────────────────────
//  VENDORS
// ─────────────────────────────────────────────
async function loadVendors() {
  var tbody = document.getElementById('vendor-tbody');
  tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--ink-4);padding:40px">Loading…</td></tr>';
  try {
    var r = await fetch('/kyv/vendors');
    var vendors = await r.json();
    setTxt('vendor-count', vendors.length + ' vendor' + (vendors.length !== 1 ? 's' : '') + ' discovered');
    if (!vendors.length) {
      tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--ink-4);padding:40px">No vendors discovered yet. Connect a Google Drive folder and run ingestion.</td></tr>';
      return;
    }
    tbody.innerHTML = vendors.map(function(v) {
      var band  = (v.band || '').toLowerCase();
      var bdg   = band === 'healthy' ? 'bdg-green' : band === 'atrisk' ? 'bdg-amber' : band === 'critical' ? 'bdg-red' : 'bdg-grey';
      // confidence is 0-1; show as % or '—' for unscored KYV vendors
      var conf  = (v.confidence != null && v.confidence > 0)
                    ? (v.confidence * 100).toFixed(0) + '%' : '—';
      return '<tr>'
        + '<td><div class="vt-name">' + esc(v.name) + '</div>'
        +     '<div class="vt-id">'   + esc(v.entityId) + '</div></td>'
        + '<td><span class="bdg ' + bdg + '">' + esc(v.band || 'Unknown') + '</span></td>'
        + '<td>' + esc(v.stance || 'Unknown') + '</td>'
        + '<td><span class="score-val">' + conf + '</span></td>'
        + '<td>' + esc(v.asOf ? new Date(v.asOf).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'2-digit'}) : '—') + '</td>'
        + '</tr>';
    }).join('');
  } catch(e) {
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--urgent-ink);padding:40px">Error loading vendors. Is the server running?</td></tr>';
  }
}

function refreshAll() {
  var active = document.querySelector('.tab-panel.on');
  if (active && active.id === 'panel-vendors') loadVendors();
}

// ─────────────────────────────────────────────
//  INGESTION
// ─────────────────────────────────────────────
function addLog(msg, type) {
  var body = document.getElementById('log-body');
  // Clear idle message on first real line
  var idle = body.querySelector('.log-idle');
  if (idle) idle.remove();
  var ts   = new Date().toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
  var line = document.createElement('div');
  line.className = 'log-line';
  line.innerHTML = '<span class="log-ts">' + ts + '</span><span class="log-msg ' + esc(type || 'info') + '">' + esc(msg) + '</span>';
  body.appendChild(line);
  body.scrollTop = body.scrollHeight;
}

function clearLog() {
  var body = document.getElementById('log-body');
  body.innerHTML = '';
}

function setLogStatus(state, text) {
  var el  = document.getElementById('log-status');
  el.className = 'log-status ' + state;
  setTxt('log-status-text', text);
}

async function runIngestion() {
  var url = (document.getElementById('drive-url').value || '').trim();
  if (!url) { document.getElementById('drive-url').focus(); return; }
  if (S.running) return;

  S.running = true;
  document.getElementById('btn-run').disabled = true;
  clearLog();
  setLogStatus('running', 'Running…');

  startSse();

  addLog('Starting ingestion…', 'info');
  addLog('Drive URL: ' + url, 'dl');

  try {
    var r = await fetch('/kyv/run', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({driveUrl: url})
    });
    var data = await r.json();

    if (!r.ok) {
      var errMsg = data.detail || data.error || ('HTTP ' + r.status);
      addLog('Failed: ' + errMsg, 'err');
      setLogStatus('error', 'Failed');
    } else {
      if (data.stages && data.stages.length) {
        data.stages.forEach(function(s) {
          addLog('Stage ' + s.order + '  ' + s.name + '  (' + s.itemsProcessed + ' items processed)', 'stage');
        });
      }
      if (data.unreadableDocuments && data.unreadableDocuments.length) {
        data.unreadableDocuments.forEach(function(u) {
          addLog('Skipped  ' + (u.path || u.relativePath) + '  — ' + u.reason, 'warn');
        });
      }
      addLog('Run ID: ' + data.runId, 'ok');
      addLog('Status: ' + (data.status || 'Completed'), 'ok');
      setLogStatus('done', 'Complete');
      // Switch to Vendors tab to show results
      setTimeout(function() { switchTab('vendors', null, false); }, 1200);
    }
  } catch(e) {
    addLog('Request error: ' + e.message, 'err');
    setLogStatus('error', 'Error');
  } finally {
    S.running = false;
    document.getElementById('btn-run').disabled = !S.connected;
    stopSse();
  }
}

// ─────────────────────────────────────────────
//  SSE — live event stream
// ─────────────────────────────────────────────
function startSse() {
  stopSse();
  S.sse = new EventSource('/events');
  S.sse.onmessage = function(e) {
    try { handleEvent(JSON.parse(e.data)); } catch(ex) {}
  };
  S.sse.onerror = function() { stopSse(); };
}

function stopSse() {
  if (S.sse) { S.sse.close(); S.sse = null; }
}

function handleEvent(msg) {
  if (!msg || !msg.type) return;
  switch(msg.type) {
    case 'kyv-started':
      addLog('Pipeline started by server', 'info');
      break;
    case 'kyv-downloading':
      addLog('Downloading from Google Drive…', 'dl');
      if (msg.data && msg.data.fileCount)
        addLog('Found ' + msg.data.fileCount + ' file(s)', 'dl');
      break;
    case 'kyv-stage':
      if (msg.data)
        addLog('Stage: ' + msg.data.name + ' (' + (msg.data.itemsProcessed || 0) + ' items)', 'stage');
      break;
    case 'kyv-complete':
      addLog('Pipeline finished — loading discovered vendors…', 'ok');
      loadVendors();
      switchTab('vendors');
      break;
    case 'kyv-error':
      addLog('Server error: ' + (msg.data && msg.data.error || 'Unknown'), 'err');
      break;
  }
}

// ─────────────────────────────────────────────
//  TWEAKS
// ─────────────────────────────────────────────
var TWEAKS = {accent: 'coral'};
function applyTweaks() {
  document.documentElement.setAttribute('data-accent', TWEAKS.accent);
  document.querySelectorAll('#tw-accent .tw-swatch').forEach(function(s) {
    s.classList.toggle('on', s.dataset.accent === TWEAKS.accent);
  });
}
function setTweak(k, v) { TWEAKS[k] = v; applyTweaks(); }
function tTweaks() { document.getElementById('tweaks').classList.toggle('open'); }
document.querySelectorAll('#tw-accent .tw-swatch').forEach(function(s) {
  s.addEventListener('click', function() { setTweak('accent', s.dataset.accent); });
});
applyTweaks();

// Design-mode edit protocol (preserves compatibility with Claude Design tool)
window.addEventListener('message', function(e) {
  var m = e.data;
  if (!m || typeof m !== 'object') return;
  if (m.type === '__activate_edit_mode')   document.getElementById('tweaks').classList.add('open');
  if (m.type === '__deactivate_edit_mode') document.getElementById('tweaks').classList.remove('open');
});
try { window.parent.postMessage({type: '__edit_mode_available'}, '*'); } catch(e) {}

// ─────────────────────────────────────────────
//  UTILS
// ─────────────────────────────────────────────
function esc(s) {
  return String(s || '')
    .replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function setTxt(id, txt) {
  var el = document.getElementById(id);
  if (el) el.textContent = txt;
}

// ─────────────────────────────────────────────
//  BOOT
// ─────────────────────────────────────────────
checkAuth();
</script>
</body>
</html>
