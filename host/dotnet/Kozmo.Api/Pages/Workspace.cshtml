    <div class="view on" id="view-prog">
      <div class="pv-content">
        <div class="page-hdr" id="prog-page-hdr">
          <div class="phdr-top">
            <div>
              <div class="phdr-eyebrow" id="prog-eyebrow">Kozmo · Vendor Cleanup Program</div>
              <div class="phdr-title" id="prog-title">Vendor Cleanup Program</div>
              <div class="phdr-sub">Deduplicate, validate, and enrich the full vendor master — one clean, complete, and trusted record for every active vendor relationship.</div>
            </div>
            <div class="phdr-right">
              <div class="status-pill"><span class="status-pill-dot"></span>Active</div>
              <div class="phdr-meta" id="prog-meta">Loading vendor count…</div>
            </div>
          </div>
          <div class="tab-bar">
            <button class="tab-btn on" data-tab="overview" onclick="switchTab('overview', this, false)">Overview</button>
            <button class="tab-btn" data-tab="detail" onclick="switchTab('detail', this, false)">Program Detail</button>
          </div>
        </div>

        <div class="tab-panels">
          <div class="tab-panel on" id="panel-overview">
            <div class="overview-body">
              <div class="overview-main">
                <div class="vendor-card" style="margin-bottom:var(--s5)">
                  <h4>Run Real Ingestion</h4>
                  <p style="color:var(--ink-3);font-size:13px;margin:6px 0 var(--s4)">
                    Paste a Google Drive folder URL and run the real pipeline. Discovered vendors replace
                    nothing — they're added to the list below alongside anything already known.
                  </p>
                  <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
                    <input id="drive-url" type="text" placeholder="Paste your Google Drive folder link…"
                           style="flex:1;min-width:280px;background:var(--canvas);border:1px solid var(--line-1);border-radius:var(--r-md);padding:8px 12px;font-size:13px;color:var(--ink-1)">
                    <button class="btn-s p" id="btn-run" onclick="runIngestion()" disabled>Run</button>
                  </div>
                  <div style="display:flex;align-items:center;gap:8px;margin-top:var(--s4)">
                    <span class="log-status idle" id="log-status"><span class="ls-dot"></span><span id="log-status-text">Idle</span></span>
                  </div>
                  <div id="log-body" class="log-body" style="margin-top:var(--s3);border-radius:var(--r-md)">
                    <div class="log-idle">No ingestion run yet.</div>
                  </div>
                </div>

                <div class="program-summary-card">
