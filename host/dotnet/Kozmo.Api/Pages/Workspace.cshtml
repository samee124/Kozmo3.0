  .ledger-item:last-child{border-bottom:none}
  .ledger-date{width:52px;flex-shrink:0;color:var(--ink-3);font-weight:500}
  .ledger-text{color:var(--ink-2);line-height:1.6}
  .vendor-notice{background:#F5F7FF;border:1px solid #DDE6FD;border-radius:var(--r-md);padding:18px 20px;margin-bottom:var(--s5)}
  .vendor-notice p{color:var(--ink-2);line-height:1.75}
  .vendor-notice a{color:var(--accent);font-weight:600}
  .detail-grid{display:grid;grid-template-columns:1.8fr 1fr;gap:var(--s5)}
  .detail-card{background:var(--surface);border:1px solid var(--line-1);border-radius:var(--r-lg);padding:var(--s6);box-shadow:var(--shadow-sm);margin-bottom:var(--s5)}
  .detail-row{display:flex;justify-content:space-between;gap:var(--s4);margin-top:var(--s4);font-size:14px;color:var(--ink-2)}
  .detail-key{font-weight:600;color:var(--ink-3)}
  .detail-value{font-weight:700;color:var(--ink-0)}
  .detail-big{font-size:28px;font-weight:700;color:var(--ink-0);margin-top:var(--s4);margin-bottom:var(--s3)}
  .assistant-panel{background:var(--surface);border:1px solid var(--line-1);border-radius:var(--r-lg);overflow:hidden}
  .assistant-header{display:flex;align-items:center;justify-content:space-between;padding:var(--s5);border-bottom:1px solid var(--line-1)}
  .assistant-title{font-size:13px;font-weight:700;color:var(--ink-0)}
  .assistant-status{display:inline-flex;align-items:center;gap:8px;font-size:12px;color:var(--affirm-ink)}
  .assistant-status-dot{width:8px;height:8px;border-radius:50%;background:var(--affirm)}
  .assistant-body{padding:var(--s5);font-size:14px;color:var(--ink-2);line-height:1.8}
  .assistant-footer{padding:var(--s5);border-top:1px solid var(--line-1);display:flex;gap:var(--s2);flex-wrap:wrap}
  .assistant-btn{font-size:12px;font-weight:600;padding:8px 12px;border-radius:999px;border:1px solid var(--line-1);background:var(--surface);color:var(--ink-1);cursor:pointer;transition:background var(--tr)}
  .assistant-btn:hover{background:var(--surface-hover)}

/* Icons */
.glyph{width:16px;height:16px;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;vertical-align:middle;display:inline-block}
.glyph.sm{width:14px;height:14px}
.glyph.xs{width:12px;height:12px}
.glyph.lg{width:20px;height:20px}

/* Tweaks panel */
.tweaks{
  position:fixed;bottom:var(--s6);right:var(--s6);z-index:500;
  display:none;background:var(--surface);border:1px solid var(--line-1);
  border-radius:var(--r-lg);box-shadow:var(--shadow-lg);min-width:220px;overflow:hidden;
}
.tweaks.open{display:block}
.tw-h{display:flex;align-items:center;justify-content:space-between;padding:var(--s4) var(--s5);border-bottom:1px solid var(--line-1)}
.tw-t{font-size:var(--t-small);font-weight:600;color:var(--ink-0)}
.tw-x{color:var(--ink-3);cursor:pointer;display:flex}
.tw-b{padding:var(--s3) var(--s5) var(--s5)}
.tw-sec{margin-bottom:var(--s4)}
.tw-sec:last-child{margin-bottom:0}
.tw-l{font-size:var(--t-micro);font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);margin-bottom:var(--s2)}
.tw-row{display:flex;gap:var(--s1);flex-wrap:wrap}
.tw-swatch{width:22px;height:22px;border-radius:50%;cursor:pointer;transition:transform var(--tr);border:2px solid transparent}
.tw-swatch.on{border-color:var(--ink-0);transform:scale(1.15)}

/* Float tweaks trigger */
.float-settings{
  position:fixed;bottom:var(--s6);right:var(--s6);z-index:50;
  width:40px;height:40px;border-radius:50%;
  background:var(--surface);border:1px solid var(--line-1);
  box-shadow:var(--shadow-md);
  display:flex;align-items:center;justify-content:center;
  color:var(--ink-3);cursor:pointer;
  transition:background var(--tr),color var(--tr),box-shadow var(--tr);
}
.float-settings:hover{background:var(--surface-hover);color:var(--ink-1);box-shadow:var(--shadow-lg)}

.slbl{font-size:var(--t-micro);font-weight:600;letter-spacing:.08em;color:var(--ink-3);text-transform:uppercase;margin-bottom:var(--s4)}
</style>
</head>
<body>

