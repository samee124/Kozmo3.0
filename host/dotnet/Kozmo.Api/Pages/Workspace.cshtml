function filterVendorTable() {
  var query = (document.getElementById('vendor-search').value || '').toLowerCase().trim();
  document.querySelectorAll('#vendor-tbody tr').forEach(function(row) {
    var text = row.textContent.toLowerCase();
    row.style.display = query && text.indexOf(query) === -1 ? 'none' : '';
