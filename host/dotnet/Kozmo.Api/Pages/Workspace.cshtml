function renderDecisions(containerId, items) {
  var el = document.getElementById(containerId);
  if (!el) return;
  if (!items || !items.length) { el.innerHTML = '<p style="color:var(--ink-3)">No decisions recorded yet.</p>'; return; }
  el.innerHTML = items.map(function(d) {
    return '<div class="decision-card"><span class="decision-status ' + d.status + '">' + (d.status === 'recorded' ? 'Recorded' : 'Pending') + '</span><div class="decision-title">' + d.title + '</div><div class="decision-detail">' + d.detail + '</div></div>';
  }).join('');
}

function renderLedger(containerId, items) {
  var el = document.getElementById(containerId);
  if (!el) return;
  if (!items || !items.length) { el.innerHTML = '<p style="color:var(--ink-3)">No activity recorded yet.</p>'; return; }
  el.innerHTML = items.map(function(l) {
    return '<div class="ledger-item"><div class="ledger-date">' + l.date + '</div><div class="ledger-text">' + l.text + '</div></div>';
  }).join('');
}

