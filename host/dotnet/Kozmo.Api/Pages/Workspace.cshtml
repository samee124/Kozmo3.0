      <div class="pv-content">

        <!-- Page header -->
        <div class="page-hdr">
          <div class="phdr-top">
            <div>
              <div class="phdr-eyebrow">Program</div>
              <div class="phdr-title" id="prog-title">Vendor Cleanup</div>
              <div class="phdr-sub">Ingest documents from Google Drive, run the vendor intelligence pipeline, and monitor posture in real time.</div>
            </div>
            <div class="phdr-right">
              <div class="status-pill disc" id="drive-pill">
