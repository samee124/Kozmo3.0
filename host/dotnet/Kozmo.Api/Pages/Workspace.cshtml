// ─────────────────────────────────────────────
//  VENDORS
// ─────────────────────────────────────────────
function loadVendors() {
  var tbody = document.getElementById('vendor-tbody');
  var placeholder = '<span style="color:var(--ink-3)">—</span>';
  if (!S.programId) {
    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--ink-3);padding:20px">' +
      'Select a program first.</td></tr>';
    return;
  }
  fetch('/programs/' + S.programId + '/vendors')
    .then(function(r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function(vendors) {
      var count = vendors.length;
      setTxt('vendor-count', count + ' vendor' + (count === 1 ? '' : 's') + ' in scope');
      var showingEl = document.getElementById('vendor-showing');
      if (showingEl) showingEl.textContent = 'Showing ' + count + ' of ' + count + ' vendors';

      tbody.innerHTML = vendors.map(function(v) {
        var band = v.band || 'Unknown';
        var statusClass = band === 'Healthy' ? 'bdg-green'
                         : band === 'Critical' ? 'bdg-red'
                         : band === 'AtRisk' ? 'bdg-amber'
                         : 'bdg-grey';
        var shortId = (v.entityId || '').substring(0, 8);
        return '<tr onclick="showVendorDetail(\'' + v.name.replace(/'/g, "\\'") + '\', \'' + v.entityId + '\')">'
          + '<td><div class="vt-name">' + v.name + '</div><div class="vt-id" title="' + v.entityId + '">' + shortId + '</div></td>'
          + '<td>' + placeholder + '</td>'
          + '<td>' + placeholder + '</td>'
          + '<td>' + placeholder + '</td>'
          + '<td>' + placeholder + '</td>'
          + '<td>' + placeholder + '</td>'
          + '<td>' + placeholder + '</td>'
          + '<td><span class="bdg ' + statusClass + '">' + band + '</span></td>'
          + '</tr>';
      }).join('');
    })
    .catch(function(err) {
      tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--urgent);padding:20px">Failed to load vendors: ' + err.message + '</td></tr>';
    });
}

function refreshAll() {
  var active = document.querySelector('.tab-panel.on');
  if (active && active.id === 'panel-vendors') loadVendors();
}

function setVendorDetailTab(tabName, triggerEl) {
