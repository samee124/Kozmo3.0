// ══════════════════════════════════════════════
//  KOZMO WORKSPACE  —  Client-side logic
// ══════════════════════════════════════════════

var S = {
  screen: 'login',
  email: null,
  connected: false,
  running: false,
  sse: null,
  programName: '',
  programId: null,
  programs: []
};

// ─────────────────────────────────────────────
//  SCREEN MANAGEMENT
// ─────────────────────────────────────────────
function show(name) {
  ['login','home','app'].forEach(function(n) {
    document.getElementById('screen-' + n).classList.toggle('hidden', n !== name);
  });
  S.screen = name;
  // Show/hide settings button in app only
  var btn = document.getElementById('float-settings-btn');
  if (btn) btn.style.display = name === 'app' ? 'flex' : 'none';
}

function goHome() {
  // Show the in-app Home with sticky sidebar instead of the full-screen home
  showAppHome();
  stopSse();
}

function enterProgram(id, name) {
  S.programId   = id;
  S.programName = name || 'Program';
  var progTitle = document.getElementById('prog-title');
  if (progTitle) progTitle.textContent = name || 'Program';
  var progEyebrow = document.getElementById('prog-eyebrow');
  if (progEyebrow) progEyebrow.textContent = 'Kozmo · ' + (name || 'Program');
  var bcProg = document.getElementById('bc-prog');
  if (bcProg) bcProg.textContent = name || 'Program';
  var sbName = document.getElementById('sb-prog-name');
  if (sbName) sbName.textContent = name || 'Program';
  show('app');
  setSidebarActive('program');
  document.querySelectorAll('.view').forEach(function(v) {
    v.classList.remove('on');
  });
  var vp = document.getElementById('view-prog');
  if (vp) vp.classList.add('on');
  // Entering a program always lands on its Overview. Without this, navigating
  // Program -> Vendors -> a vendor -> Program left panel-vendor-detail showing under a
  // "Program" sidebar label — only switchTab() ever touched .tab-panel/.tab-btn/prog-page-hdr
  // before, so whatever panel was last active (e.g. vendor-detail) stayed active. Mirrors
  // exactly what switchTab('overview') itself does to those same elements.
  document.querySelectorAll('.tab-panel').forEach(function(p) {
    p.classList.remove('on');
  });
  var overviewPanel = document.getElementById('panel-overview');
  if (overviewPanel) overviewPanel.classList.add('on');
  document.querySelectorAll('.tab-btn').forEach(function(b) {
    b.classList.toggle('on', b.dataset.tab === 'overview');
  });
  var progHdr = document.getElementById('prog-page-hdr');
  if (progHdr) progHdr.style.display = '';
  loadProgramVendorCount();
}

// Re-enters whichever program is already selected (S.programId, set by loadPrograms() as soon
// as GET /programs resolves) — used by every persistent nav element (the sidebar "Program" link,
// the pre-fetch fallback tiles) instead of each hardcoding the fake 'vcp' id. Without this, the
// sidebar link reset S.programId back to 'vcp' on every click even after a real program had
// already loaded, which is what caused GET /programs/vcp/vendors -> 400 -> "undefined vendors in
// scope" (fetch() doesn't reject on HTTP error status, so the {"error":...} body silently parsed
// as the vendor list). Falls back to the same 'vcp' placeholder only if no real program has
// loaded yet at all (e.g. GET /programs hasn't resolved) — loadProgramVendorCount()'s r.ok check
// now fails that case gracefully instead of showing "undefined".
function enterCurrentProgram() {
  enterProgram(S.programId || 'vcp', S.programName || 'Vendor Cleanup Program');
}

// ─────────────────────────────────────────────
//  PROGRAMS
// ─────────────────────────────────────────────
function loadPrograms() {
  fetch('/programs')
    .then(function(r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function(programs) {
      S.programs = Array.isArray(programs) ? programs : [];
      renderProgramTiles('home-prog-grid');
      renderProgramTiles('app-prog-grid');
      if (!S.programId && S.programs.length > 0) {
        S.programId   = S.programs[0].id;
        S.programName = S.programs[0].name;
        var progTitle = document.getElementById('prog-title');
        if (progTitle) progTitle.textContent = S.programName;
        var progEyebrow = document.getElementById('prog-eyebrow');
        if (progEyebrow) progEyebrow.textContent = 'Kozmo · ' + S.programName;
        var bcProg = document.getElementById('bc-prog');
        if (bcProg) bcProg.textContent = S.programName;
        var sbName = document.getElementById('sb-prog-name');
        if (sbName) sbName.textContent = S.programName;
      }
      if (S.programId) loadProgramVendorCount();
    })
    .catch(function() {
      // Leave the fallback tile/labels in place — an honest "couldn't load" is better than
      // fabricating a program list.
    });
}

// Real vendor count for the phdr-meta line — separate from loadVendors() (the vendors-tab
// table) so entering a program shows a real number immediately, before the Vendors tab is
// ever opened.
function loadProgramVendorCount() {
  var meta = document.getElementById('prog-meta');
  if (!meta || !S.programId) return;
  fetch('/programs/' + S.programId + '/vendors')
    .then(function(r) {
      // fetch() only rejects on network failure, never on HTTP error status (e.g. 400 for a
      // stale/invalid program id) — without this check, an error body like
      // {"error":"invalid program id"} silently parses as "vendors" and (errorObj).length
      // renders as the literal string "undefined vendors in scope" instead of failing loudly.
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function(vendors) {
      var count = Array.isArray(vendors) ? vendors.length : 0;
      meta.textContent = count + ' vendor' + (count === 1 ? '' : 's') + ' in scope';
    })
    .catch(function() { meta.textContent = 'Vendor count unavailable'; });
}

function renderProgramTiles(gridId) {
  var grid = document.getElementById(gridId);
  if (!grid || S.programs.length === 0) return;

  var tiles = S.programs.map(function(p) {
    var safeName = String(p.name).replace(/'/g, "\\'");
    return '<div class="prog-tile" onclick="enterProgram(\'' + p.id + '\', \'' + safeName + '\')">'
      + '<div class="prog-ico"><svg class="glyph lg"><use href="#g-building"/></svg></div>'
      + '<div class="prog-name">' + p.name + '</div>'
      + '<div class="prog-desc">Ingest vendor documents directly from Google Drive. Classify signals, compute risk posture, and surface renewal obligations across your entire vendor portfolio.</div>'
      + '<div class="prog-foot"><span class="prog-badge active">Active</span><span class="prog-arrow"><svg class="glyph lg"><use href="#g-arrow-right"/></svg></span></div>'
      + '</div>';
  }).join('');

  var comingSoon =
    '<div class="prog-tile inactive">'
    + '<div class="prog-ico"><svg class="glyph lg"><use href="#g-prog"/></svg></div>'
    + '<div class="prog-name">Contract Intelligence</div>'
    + '<div class="prog-desc">Automated contract review — extract SLA terms, flag anomalies, and surface renewal obligations across all vendor agreements.</div>'
    + '<div class="prog-foot"><span class="prog-badge soon">Coming soon</span></div>'
    + '</div>';

  grid.innerHTML = tiles + comingSoon;
}

// Keep sidebar selection in sync when navigating
function setSidebarActive(navKey) {
  document.querySelectorAll('.nav-list .nv').forEach(function(n) {
    var key = n.dataset.nav || n.dataset.tabNav;
    n.classList.toggle('on', key === navKey);
  });
}

// Show the in-app Home view (keep sidebar visible)
function showAppHome() {
  show('app');
  setSidebarActive('home');
  // Activate the home view inside the app and hide program view
  document.querySelectorAll('.view').forEach(function(v) {
    v.classList.remove('on');
  });
  var vh = document.getElementById('view-home');
  if (vh) vh.classList.add('on');
  // Ensure the tab-panel inside view-home is visible
  document.querySelectorAll('#view-home .tab-panel').forEach(function(p) {
    p.classList.add('on');
  });
}

function signOut() {
  S.email = null;
  S.connected = false;
  stopSse();
  show('login');
}

// ─────────────────────────────────────────────
//  AUTH CHECK
// ─────────────────────────────────────────────
async function checkAuth() {
  try {
    var r = await fetch('/auth/google/status');
    var d = await r.json();
    S.email = d.email || null;
    S.connected = d.connected && !d.tokenExpired;
    applyUserUI();
    // #drive-card and its connect/disconnect controls don't exist in this page's markup, so
    // updateDriveCard() (which needs them) can't run — but #btn-run does exist and must reflect
    // real connection state directly, or it stays permanently disabled even when truly connected.
    var btnRun = document.getElementById('btn-run');
    if (btnRun) btnRun.disabled = !S.connected || S.running;
    if (d.connected) {
      showAppHome();
      loadPrograms();
    } else {
      show('login');
    }
  } catch(e) {
    show('login');
  }
}

function applyUserUI() {
  var e = S.email || '';
  var initials = e ? (e[0] || '?').toUpperCase() : '?';

  // Home
  setTxt('home-email', e);
  setTxt('home-av', initials);
  if (e) {
    var hr = new Date().getHours();
    var greet = hr < 12 ? 'Good morning' : hr < 17 ? 'Good afternoon' : 'Good evening';
    setTxt('home-greeting-full', greet + ', ' + e.split('@@')[0]);
    setTxt('home-greeting-app', greet + ', ' + e.split('@@')[0]);
  }

  // Sidebar / topbar
  setTxt('sb-av', initials);
  setTxt('sb-uname', e || 'User');
  setTxt('top-av', initials);
}

function updateDriveCard() {
  var card     = document.getElementById('drive-card');
  var ico      = document.getElementById('drive-ico');
  var email    = document.getElementById('drive-email');
  var pill     = document.getElementById('drive-pill');
  var pillTxt  = document.getElementById('drive-pill-text');
  var btnConn  = document.getElementById('btn-connect');
  var btnDisc  = document.getElementById('btn-disconnect');
  var btnRun   = document.getElementById('btn-run');

  if (!card || !ico || !email || !pill || !pillTxt || !btnConn || !btnDisc) {
    return;
  }

  if (S.connected && S.email) {
    card.className      = 'drive-card conn';
    ico.className       = 'drive-card-ico conn';
    email.textContent   = S.email;
    pill.className      = 'status-pill conn';
    pillTxt.textContent = S.email;
    btnConn.style.display = 'none';
    btnDisc.style.display = 'inline-flex';
    if (btnRun) btnRun.disabled = false;
  } else {
    card.className      = 'drive-card disc';
    ico.className       = 'drive-card-ico disc';
    email.textContent   = 'Not connected — authorize to ingest documents';
    pill.className      = 'status-pill disc';
    pillTxt.textContent = 'Not connected';
    btnConn.style.display = 'inline-flex';
    btnDisc.style.display = 'none';
    if (btnRun) btnRun.disabled = true;
  }
}

function disconnectDrive() {
  S.connected = false;
  S.email = null;
  updateDriveCard();
  applyUserUI();
  show('login');
}

// ─────────────────────────────────────────────
//  TAB SWITCHING
// ─────────────────────────────────────────────
function switchTab(name, triggerEl, silent) {
  // switchTab only toggles .tab-btn/.tab-panel/.nv classes — unlike enterProgram(), it never
  // activated #view-prog itself. Coming from Home (#view-home showing), clicking any tab
  // (vendors/overview/detail/vendor-detail) moved the sidebar highlight and the tab-panel class
  // but left #view-home visible, so no content ever appeared. Only acts when view-prog isn't
  // already the active view, so this is a no-op (zero behavior change) once already inside Program.
  var viewProg = document.getElementById('view-prog');
  if (viewProg && !viewProg.classList.contains('on')) {
    document.querySelectorAll('.view').forEach(function(v) { v.classList.remove('on'); });
    viewProg.classList.add('on');
  }
  document.querySelectorAll('.tab-btn').forEach(function(b) {
    b.classList.toggle('on', b.dataset.tab === name);
  });
  document.querySelectorAll('[data-tab-nav]').forEach(function(n) {
    n.classList.toggle('on', n.dataset.tabNav === name);
  });
  // Sidebar nav highlighting: ensure only the matching nav item is shown as active.
  // Items may use either data-tab-nav (tab-driven) or data-nav (persistent views).
  document.querySelectorAll('.nv').forEach(function(n) {
    var tabNav = n.dataset.tabNav;
    var nav = n.dataset.nav;
    if (name === 'vendor-detail') {
      // A vendor detail page is reached from, and stays within, the Vendors section — the
      // sidebar must keep "Vendors" highlighted, not jump back to "Program".
      n.classList.toggle('on', tabNav === 'vendors');
    } else if (name === 'overview' || name === 'detail') {
      // The Program page's own tab bar (Overview / Program Detail) uses data-tab, a different
      // attribute from the sidebar's data-nav/data-tab-nav — neither ever matches 'overview' or
      // 'detail', so without this branch every sidebar item loses .on the moment either tab is
      // clicked. Both tabs are still the Program page — keep "Program" highlighted.
      n.classList.toggle('on', nav === 'program');
    } else {
      n.classList.toggle('on', (tabNav && tabNav === name) || (nav && nav === name));
    }
  });
  document.querySelectorAll('.tab-panel').forEach(function(p) {
    p.classList.remove('on');
  });
  var panel = document.getElementById('panel-' + name);
  if (panel) panel.classList.add('on');
  var progHdr = document.getElementById('prog-page-hdr');
  if (progHdr) progHdr.style.display = (name === 'overview' || name === 'detail') ? '' : 'none';
  if (name === 'vendors' && !silent) loadVendors();
  if (name === 'vendor-detail') {
    // Show breadcrumb vendor links when entering vendor-detail
    var sepV = document.getElementById('bc-sep-vendors');
    var bcVendors = document.getElementById('bc-vendors');
    var sepVendor = document.getElementById('bc-sep-vendor');
    var bcVendor = document.getElementById('bc-vendor');
    if (sepV) sepV.style.display = 'inline';
    if (bcVendors) bcVendors.style.display = 'inline';
    if (sepVendor) sepVendor.style.display = 'inline';
    if (bcVendor) bcVendor.style.display = 'inline';
  }
  else {
    // Hide vendor breadcrumb pieces when not on vendor-detail
    var sepV = document.getElementById('bc-sep-vendors');
    var bcVendors = document.getElementById('bc-vendors');
    var sepVendor = document.getElementById('bc-sep-vendor');
    var bcVendor = document.getElementById('bc-vendor');
    if (sepV) sepV.style.display = 'none';
    if (bcVendors) bcVendors.style.display = 'none';
    if (sepVendor) sepVendor.style.display = 'none';
    if (bcVendor) bcVendor.style.display = 'none';
  }
}

// ─────────────────────────────────────────────
//  SIDEBAR COLLAPSE
