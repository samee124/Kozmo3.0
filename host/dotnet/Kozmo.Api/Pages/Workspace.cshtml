  /* Same fix as .vendors-panel > .vendor-card{flex-shrink:0} — .vendor-card's own min-height:0
     (below) disables the browser's default "flex item can't shrink below its content" floor, so
     without an explicit flex-shrink:0 here too, the relocated ingestion card (a direct flex child
     of this column) can collapse toward its flex-basis while its content (default overflow:visible)
     spills out past the shrunk box. */
  .overview-main > .vendor-card{flex-shrink:0}
