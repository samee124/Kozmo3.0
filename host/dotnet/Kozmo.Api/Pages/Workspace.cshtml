          <div class="tab-bar">
            <button class="tab-btn on" data-tab="ingest" onclick="switchTab('ingest',this)">Ingestion</button>
            <button class="tab-btn" data-tab="vendors" onclick="switchTab('vendors',this)">Vendors</button>
          </div>
        </div>

        <!-- Tab panels -->
        <div class="tab-panels">

