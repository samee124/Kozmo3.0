// Overwrites the completeness/gaps banner and the activity list with REAL data for the clicked
// vendor. Does not fabricate: fields the backend doesn't provide are blanked to "—", not guessed.
function loadRealVendorDetail(vendorId) {
  ['detail-cri', 'detail-cri-delta', 'detail-contract', 'detail-spend-ytd', 'detail-annual-spend',
   'detail-sla', 'detail-response', 'detail-response-target', 'detail-open-tasks', 'detail-compliance-status']
    .forEach(function(id) { setTxt(id, '—'); });
  setTxt('detail-vendor-sub',
    'Real ingested vendor — completeness, check-ins, and contract evidence below reflect actual ' +
    'pipeline data. Files & Artifacts, tags, and other sections are placeholder content, not yet ' +
    'wired to real data.');

  var linksEl = document.getElementById('detail-action-links');
  if (linksEl) linksEl.innerHTML = '';

  // Source documents are deleted after processing (by design — see KYV pipeline), so there is no
  // real file list to show. Overwrite the mock Files & Artifacts rows with an honest empty state
  // instead of leaving fabricated filenames/sources under a banner that claims real data.
  var filesBody = document.getElementById('detail-files-body');
  if (filesBody) {
    filesBody.innerHTML = '<tr><td colspan="5" style="color:var(--ink-3)">' +
      'No stored files for this vendor — source documents are not retained after processing.</td></tr>';
  }

  fetch('/vendors/' + vendorId + '/vendor-file')
    .then(function(r) { return r.json(); })
    .then(function(vf) {
      var comp   = vf.completeness || { ratio: 0, filledKeys: [], gapKeys: [] };
      var known  = (comp.filledKeys || []).length;
      var gaps   = (comp.gapKeys || []).length;
      var total  = known + gaps;
      var pct    = Math.round((comp.ratio || 0) * 100);

      setTxt('detail-action-title', 'REAL COMPLETENESS — WHAT WE ACTUALLY KNOW');
      setTxt('detail-action-text',
        pct + '% complete (' + known + ' of ' + total + ' tracked fields known). ' +
        (gaps > 0
          ? 'The remaining ' + gaps + ' field(s) are honest blind spots — not yet extracted from any document or check-in.'
          : 'Every tracked field for this vendor is currently known.'));
      var metaEl = document.getElementById('detail-action-meta');
      if (metaEl) metaEl.innerHTML =
        '<span>' + (vf.evidenceCount || 0) + ' evidence document(s)</span><span>' + (vf.claimsCount || 0) + ' tracked claim(s)</span>';

      // Real completeness bar (was a fabricated "Stage 4 of 5" pipeline narrative + fake %).
      setTxt('detail-stage', 'Vendor profile — ' + known + '/' + total + ' fields known');
      setTxt('detail-progress-text', pct + '%');
      var bar = document.getElementById('detail-progress-bar');
      if (bar) bar.style.width = pct + '%';
      // No real "blocked item" or "next review date" signal exists yet for a freshly ingested
      // vendor — blank rather than show the fabricated Northstar text next to real numbers.
      setTxt('detail-blocked', gaps > 0 ? gaps + ' field(s) not yet known' : 'No known gaps');
      setTxt('detail-next-review', '—');

      var items = (comp.filledKeys || []).map(function(k) { return { type: 'low', text: '✓ Known: ' + k }; })
        .concat((comp.gapKeys || []).map(function(k) { return { type: 'low', text: '○ Gap: ' + k }; }));
      renderGapsList('detail-gaps', items, false);
    })
    .catch(function(err) {
      setTxt('detail-action-title', 'COMPLETENESS UNAVAILABLE');
      setTxt('detail-action-text', 'Could not load real completeness: ' + err.message);
      setTxt('detail-stage', '—');
      setTxt('detail-progress-text', '—');
      var bar2 = document.getElementById('detail-progress-bar');
      if (bar2) bar2.style.width = '0%';
      setTxt('detail-blocked', '—');
      setTxt('detail-next-review', '—');
      renderGapsList('detail-gaps', [], false);
    });

  loadVendorCheckins(vendorId);
  loadVendorEvidence(vendorId);
}

// Real contract clauses (E1 metadata) for one vendor — quoted derivations, never fabricated.
function loadVendorEvidence(vendorId) {
  var el = document.getElementById('detail-evidence');
  if (!el) return;
  el.innerHTML = '<li style="color:var(--ink-3)">Loading…</li>';

  fetch('/vendors/' + vendorId + '/metadata')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var clauses = data.clauses || [];
      if (!clauses.length) {
        el.innerHTML = '<li style="color:var(--ink-3)">No contract clauses extracted for this vendor yet.</li>';
        return;
      }
      el.innerHTML = clauses.map(function(c) { return vendorEvidenceItem(c); }).join('');
    })
    .catch(function(err) {
      el.innerHTML = '<li style="color:var(--urgent)">Could not load contract evidence: ' + esc(err.message) + '</li>';
    });
}

function evidenceFieldLabel(field) {
  return (field || '').split('_').map(function(w) {
    return w.charAt(0).toUpperCase() + w.slice(1);
  }).join(' ');
}

function vendorEvidenceItem(c) {
  var source = c.documentType ? ' <span style="color:var(--ink-4);font-size:12px">(' + esc(c.documentType) + ')</span>' : '';
  return '<li style="margin-bottom:14px;list-style:none">'
    + '<div style="font-weight:600;color:var(--ink-0);margin-bottom:2px">' + esc(evidenceFieldLabel(c.field)) + source + '</div>'
    + '<div style="font-size:13px;color:var(--ink-2)">' + esc(c.value) + '</div>'
    + '<div style="font-size:12px;color:var(--ink-4);margin-top:4px;font-style:italic">' + esc(c.derivation) + '</div>'
    + '</li>';
}

// Real, interactive check-ins for one vendor — raise -> answer -> resolved, live in the detail
// panel. Same shape/flow as Pages/Pending.cshtml's proven form (radio for YES_NO, dropdown for
// STATUS_SELECT, text input for TYPED_VALUE), reused here for consistency.
var VENDOR_CI_STATUS_OPTIONS = ['Active', 'Inactive', 'Suspended', 'Dissolved', 'Draft', 'Signed', 'None', 'Unknown'];

function loadVendorCheckins(vendorId) {
  var signals = document.getElementById('detail-signals');
  if (!signals) return;
  signals.innerHTML = '<li style="color:var(--ink-3)">Loading…</li>';

  fetch('/checkins')
    .then(function(r) { return r.json(); })
    .then(function(all) {
      var mine = all.filter(function(c) { return c.vendorId === vendorId; });
      if (!mine.length) {
        signals.innerHTML = '<li style="color:var(--ink-3)">No open check-ins for this vendor.</li>';
        return;
      }
      signals.innerHTML = mine.map(function(c) { return vendorCheckinCard(c); }).join('');
    })
    .catch(function(err) {
      signals.innerHTML = '<li style="color:var(--urgent)">Could not load check-ins: ' + esc(err.message) + '</li>';
    });
}

function vendorCheckinCard(ci) {
  return '<li style="margin-bottom:14px;list-style:none">'
    + '<div style="font-size:11px;color:var(--ink-3);margin-bottom:4px">' + esc(ci.kind) + ' · ' + esc(ci.responseShape)
    + (ci.targetField ? ' · ' + esc(ci.targetField) : '') + '</div>'
    + '<div style="margin-bottom:8px">' + esc(ci.question) + '</div>'
    + '<div id="vci-form-' + ci.checkInId + '" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">'
    + vendorCheckinInputFor(ci)
    + '<button class="btn-s p" onclick="submitVendorCheckin(\'' + ci.checkInId + '\', \'' + ci.vendorId + '\')" id="vci-btn-' + ci.checkInId + '">Submit</button>'
    + '</div>'
    + '<div id="vci-status-' + ci.checkInId + '" style="font-size:12px;margin-top:6px"></div>'
    + '</li>';
}

function vendorCheckinInputFor(ci) {
  if (ci.responseShape === 'YES_NO') {
    return '<label style="display:flex;gap:4px;align-items:center;cursor:pointer;font-size:13px">'
      + '<input type="radio" name="vci-ans-' + ci.checkInId + '" value="true"> Yes</label>'
      + '<label style="display:flex;gap:4px;align-items:center;cursor:pointer;font-size:13px;margin-right:8px">'
      + '<input type="radio" name="vci-ans-' + ci.checkInId + '" value="false"> No</label>';
  }
  if (ci.responseShape === 'STATUS_SELECT') {
    var opts = VENDOR_CI_STATUS_OPTIONS.map(function(s) { return '<option value="' + s + '">' + s + '</option>'; }).join('');
    return '<select id="vci-input-' + ci.checkInId + '"><option value="">— select —</option>' + opts + '</select>';
  }
  var ph = ci.targetField ? 'Enter ' + esc(ci.targetField) + '…' : 'Enter value…';
  return '<input type="text" id="vci-input-' + ci.checkInId + '" placeholder="' + ph + '">';
}

function submitVendorCheckin(id, vendorId) {
  var btn    = document.getElementById('vci-btn-' + id);
  var status = document.getElementById('vci-status-' + id);
  var value;

  var radios = document.querySelectorAll('input[name="vci-ans-' + id + '"]');
  if (radios.length) {
    var checked = null;
    radios.forEach(function(r) { if (r.checked) checked = r; });
    if (!checked) { status.style.color = 'var(--urgent)'; status.textContent = 'Please select Yes or No.'; return; }
    value = checked.value;
  } else {
    var inp = document.getElementById('vci-input-' + id);
    value = inp ? inp.value.trim() : '';
    if (!value) { status.style.color = 'var(--urgent)'; status.textContent = 'Please enter a value.'; return; }
  }

  btn.disabled = true;
  status.style.color = 'var(--ink-3)';
  status.textContent = 'Submitting…';

  fetch('/checkins/' + id + '/answer', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ responseValue: value })
  })
    .then(function(r) { return r.json().then(function(body) { return { ok: r.ok, body: body }; }); })
    .then(function(res) {
      if (res.ok) {
        status.style.color = 'var(--affirm)';
        status.textContent = 'Answered — refreshing…';
        setTimeout(function() { loadVendorCheckins(vendorId); }, 600);
      } else {
        status.style.color = 'var(--urgent)';
        status.textContent = res.body.error || 'Submission failed.';
        btn.disabled = false;
      }
    })
    .catch(function(err) {
      status.style.color = 'var(--urgent)';
      status.textContent = 'Network error: ' + err.message;
      btn.disabled = false;
    });
}

// ─────────────────────────────────────────────
//  INGESTION
// ─────────────────────────────────────────────
function addLog(msg, type) {
  var body = document.getElementById('log-body');
  // Clear idle message on first real line
  var idle = body.querySelector('.log-idle');
  if (idle) idle.remove();
  var ts   = new Date().toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
  var line = document.createElement('div');
  line.className = 'log-line';
  line.innerHTML = '<span class="log-ts">' + ts + '</span><span class="log-msg ' + esc(type || 'info') + '">' + esc(msg) + '</span>';
  body.appendChild(line);
  body.scrollTop = body.scrollHeight;
}

function clearLog() {
  var body = document.getElementById('log-body');
  body.innerHTML = '';
}

function setLogStatus(state, text) {
  var el  = document.getElementById('log-status');
  el.className = 'log-status ' + state;
  setTxt('log-status-text', text);
}

async function runIngestion() {
  var url = (document.getElementById('drive-url').value || '').trim();
  if (!url) { document.getElementById('drive-url').focus(); return; }
  if (S.running) return;

  S.running = true;
  document.getElementById('btn-run').disabled = true;
  clearLog();
  setLogStatus('running', 'Running…');

  startSse();

  addLog('Starting ingestion…', 'info');
  addLog('Drive URL: ' + url, 'dl');

  try {
    var r = await fetch('/kyv/run', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({driveUrl: url})
    });
    var data = await r.json();

    if (!r.ok) {
      var errMsg = data.detail || data.error || ('HTTP ' + r.status);
      addLog('Failed: ' + errMsg, 'err');
      setLogStatus('error', 'Failed');
    } else {
      if (data.stages && data.stages.length) {
        data.stages.forEach(function(s) {
          addLog('Stage ' + s.order + '  ' + s.name + '  (' + s.itemsProcessed + ' items processed)', 'stage');
        });
      }
      if (data.unreadableDocuments && data.unreadableDocuments.length) {
        data.unreadableDocuments.forEach(function(u) {
          addLog('Skipped  ' + (u.path || u.relativePath) + '  — ' + u.reason, 'warn');
        });
      }
      addLog('Run ID: ' + data.runId, 'ok');
      addLog('Status: ' + (data.status || 'Completed'), 'ok');
      setLogStatus('done', 'Complete');
      // Switch to Vendors tab to show results
      setTimeout(function() { switchTab('vendors', null, false); }, 1200);
    }
  } catch(e) {
    addLog('Request error: ' + e.message, 'err');
    setLogStatus('error', 'Error');
  } finally {
    S.running = false;
    document.getElementById('btn-run').disabled = !S.connected;
    stopSse();
  }
}

// ─────────────────────────────────────────────
//  SSE — live event stream
// ─────────────────────────────────────────────
function startSse() {
  stopSse();
  S.sse = new EventSource('/events');
  S.sse.onmessage = function(e) {
    try { handleEvent(JSON.parse(e.data)); } catch(ex) {}
  };
  S.sse.onerror = function() { stopSse(); };
}

function stopSse() {
  if (S.sse) { S.sse.close(); S.sse = null; }
}

function handleEvent(msg) {
  if (!msg || !msg.type) return;
  switch(msg.type) {
    case 'kyv-started':
      addLog('Pipeline started by server', 'info');
      break;
    case 'kyv-downloading':
      addLog('Downloading from Google Drive…', 'dl');
      if (msg.data && msg.data.fileCount)
        addLog('Found ' + msg.data.fileCount + ' file(s)', 'dl');
      break;
    case 'kyv-stage':
      if (msg.data)
        addLog('Stage: ' + msg.data.name + ' (' + (msg.data.itemsProcessed || 0) + ' items)', 'stage');
      break;
    case 'kyv-complete':
      addLog('Pipeline finished — loading discovered vendors…', 'ok');
      loadVendors();
      switchTab('vendors');
      break;
    case 'kyv-error':
      addLog('Server error: ' + (msg.data && msg.data.error || 'Unknown'), 'err');
      break;
  }
}

// ─────────────────────────────────────────────
//  TWEAKS
// ─────────────────────────────────────────────
var TWEAKS = {accent: 'coral'};
function applyTweaks() {
  document.documentElement.setAttribute('data-accent', TWEAKS.accent);
  document.querySelectorAll('#tw-accent .tw-swatch').forEach(function(s) {
    s.classList.toggle('on', s.dataset.accent === TWEAKS.accent);
  });
}
function setTweak(k, v) { TWEAKS[k] = v; applyTweaks(); }
function tTweaks() { document.getElementById('tweaks').classList.toggle('open'); }
document.querySelectorAll('#tw-accent .tw-swatch').forEach(function(s) {
  s.addEventListener('click', function() { setTweak('accent', s.dataset.accent); });
});
applyTweaks();

// Design-mode edit protocol (preserves compatibility with Claude Design tool)
window.addEventListener('message', function(e) {
  var m = e.data;
  if (!m || typeof m !== 'object') return;
  if (m.type === '__activate_edit_mode')   document.getElementById('tweaks').classList.add('open');
  if (m.type === '__deactivate_edit_mode') document.getElementById('tweaks').classList.remove('open');
});
try { window.parent.postMessage({type: '__edit_mode_available'}, '*'); } catch(e) {}

// ─────────────────────────────────────────────
//  UTILS
// ─────────────────────────────────────────────
function esc(s) {
  return String(s || '')
    .replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function setTxt(id, txt) {
  var el = document.getElementById(id);
  if (el) el.textContent = txt;
}

// ─────────────────────────────────────────────
//  BOOT
// ─────────────────────────────────────────────
checkAuth();
</script>
</body>
