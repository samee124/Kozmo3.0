        <button class="ibtn" onclick="refreshAll()" title="Refresh">
          <svg class="glyph sm"><use href="#g-refresh"/></svg>
        </button>
        <div class="avbtn" id="top-av" onclick="signOut()" title="Sign out"></div>
      </div>
    </div>

