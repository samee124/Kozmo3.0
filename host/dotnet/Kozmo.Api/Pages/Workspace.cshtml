// ─────────────────────────────────────────────
//  VENDOR DETAIL — DEEP SECTIONS (generic fallback + renderers)
// ─────────────────────────────────────────────
function criNumber(criStr) {
  var m = /(\d+)/.exec(criStr || '');
  return m ? parseInt(m[1], 10) : null;
}

function genericSections(detail, vendorName) {
  var n = criNumber(detail.cri);
  return {
    gaps: [
      { type: 'med', text: (detail.blocked || '').replace(/^Blocked:\s*/, '') || 'No blocking items identified' },
      { type: 'watch', text: 'Compliance status: ' + (detail.complianceStatus || 'unknown') },
      { type: 'low', text: (detail.nextReview || '').replace(/^Next review:\s*/, 'Next review scheduled for ') || 'No review scheduled' }
    ],
    qa: [
      { q: 'What is the current priority for ' + vendorName + '?', a: detail.actionText || 'No recommended action on file yet.', meta: (detail.actionMeta || []).slice() },
      { q: 'Is this vendor on track for its program stage?', a: (detail.stage || 'Stage not set') + '. ' + (detail.blocked || 'No blockers recorded.'), meta: ['Generated from program status'] }
    ],
    scores: [
      { value: n === null ? '—' : String(n), label: 'CRI / 100', cls: n === null ? '' : n < 60 ? 'warn' : n >= 80 ? 'good' : '' },
      { value: detail.sla || '—', label: 'SLA Compliance', cls: '' },
      { value: detail.openTasks || '—', label: 'Open Tasks', cls: '' }
    ],
    findings: [
      { type: 'med', text: detail.actionText || 'No findings generated for this vendor yet.' }
    ],
    artifacts: [
      { icon: 'g-chart', name: vendorName + ' Summary', meta: 'Not yet generated', badge: 'Not started', badgeCls: 'grey', actions: [{ label: 'Generate', cls: 'p' }] }
    ],
    plan: [
      { task: detail.actionText || 'Review vendor status', meta: (detail.actionMeta || []).join(' · ') || 'No owner assigned yet' }
    ],
    tasks: [
      [(detail.actionText || 'Review vendor').split('.')[0], 'Unassigned', '—', 'Optional', 'Not Started', 'grey']
    ],
    comms: [],
    memoryState: [
      { label: 'Vendor State', value: detail.complianceStatus || 'Active' },
      { label: 'Current CRI', value: detail.cri || '—' },
      { label: 'Next Review', value: (detail.nextReview || '').replace(/^Next review:\s*/, '') || '—' }
    ],
    decisions: [],
    ledger: [],
    sentiment: '—',
    invoiceStatus: '—'
  };
}

function renderGapsList(containerId, items, withLink) {
  var el = document.getElementById(containerId);
  if (!el) return;
  if (!items || !items.length) { el.innerHTML = '<li class="gaps-item" style="color:var(--ink-3)">No items to show.</li>'; return; }
  el.innerHTML = items.map(function(g) {
    var via = g.via ? ' <em>via ' + g.via + '</em>' : '';
    var link = withLink ? '<button class="gaps-link" onclick="setVendorDetailTab(\'details\', document.querySelectorAll(\'.vendor-tab-btn\')[1]); setVendorSubtab(\'' + (g.target || 'analysis') + '\')">→ Details</button>' : '';
    return '<li class="gaps-item"><span class="gaps-dot ' + g.type + '"></span><span class="gaps-text">' + g.text + via + '</span>' + link + '</li>';
  }).join('');
}

function renderQa(containerId, items) {
  var el = document.getElementById(containerId);
  if (!el) return;
  if (!items || !items.length) { el.innerHTML = '<p style="color:var(--ink-3)">No questions answered yet.</p>'; return; }
  el.innerHTML = items.map(function(qa) {
    return '<div class="qa-block"><div class="qa-q">' + qa.q + '</div><div class="qa-a">' + qa.a + '</div><div class="qa-meta">' + qa.meta.map(function(m) { return '<span>' + m + '</span>'; }).join('') + '</div></div>';
  }).join('');
