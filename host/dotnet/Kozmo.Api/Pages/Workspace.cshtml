@page "/workspace"
@{
    Layout = null;
}
<!doctype html>
<html lang="en" data-accent="coral" data-density="regular">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Kozmo · Workspace</title>
<style>
/* ═══════════════════════════════════════════════════════
   KOZMO WORKSPACE  —  based on Kozmo Workspace v3 design
   No external CDN — system fonts only (CI Lane 6 safe)
═══════════════════════════════════════════════════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
button{font:inherit;cursor:pointer;border:0;background:transparent;color:inherit;padding:0}
ul,ol{list-style:none}
a{color:inherit;text-decoration:none}

/* ── TOKENS ── */
:root{
  --accent:#F06A6A; --accent-hover:#E15555; --accent-soft:#FDECEC;
  --accent-soft-2:#FEF5F5; --accent-ink:#C73E3E; --accent-border:#F8D2D2;

  --canvas:#F9F9FA; --surface:#FFFFFF;
  --surface-soft:#F6F6F7; --surface-hover:#F4F4F5;

  --ink-0:#1E1F21; --ink-1:#323237; --ink-2:#54545A;
  --ink-3:#6D6E72; --ink-4:#9C9CA0; --ink-5:#C2C2C5;

  --line-1:#EDEAE9; --line-2:#F1EEED; --line-3:#E5E5E7;

  --affirm:#14A085; --affirm-soft:#E6F4F0;
  --affirm-ink:#0C7860; --affirm-border:#C8E8DE;

  --caution:#C97B17; --caution-soft:#FDF1DE;
  --caution-ink:#A06212; --caution-border:#F4D9A8;

  --urgent:#E8384F; --urgent-soft:#FCE6E9;
  --urgent-ink:#B81B33; --urgent-border:#F4C2C9;

  --watch:#4573D2; --watch-soft:#E5EDFA;
  --watch-ink:#2A56B5; --watch-border:#C3D5F1;

  --info:#4573D2; --info-soft:#E5EDFA;
  --info-ink:#2A56B5; --info-border:#C3D5F1;

  --font-ui:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
  --font-display:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
  --font-mono:ui-monospace,"Cascadia Code","Fira Mono",monospace;

  --t-display:32px; --t-title:22px; --t-h3:16px;
  --t-h4:15px; --t-body:14px; --t-small:13px; --t-micro:11px;

  --s1:4px; --s2:8px; --s3:12px; --s4:16px;
  --s5:20px; --s6:24px; --s7:32px; --s8:48px;

  --pad-card:24px; --pad-card-y:20px;
  --topbar-h:52px; --rail-w:240px;

  --r-sm:4px; --r-md:6px; --r-lg:8px; --r-pill:999px;
  --tr:180ms ease; --tr-fast:120ms ease;

  --shadow-sm:0 1px 2px rgba(0,0,0,.04);
  --shadow-md:0 2px 4px rgba(0,0,0,.04),0 1px 2px rgba(0,0,0,.02);
  --shadow-lg:0 4px 12px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.03);
}

/* Accent overrides */
:root[data-accent="indigo"]{--accent:#4573D2;--accent-hover:#3661BC;--accent-soft:#E5EDFA;--accent-soft-2:#F0F5FC;--accent-ink:#2A56B5;--accent-border:#C3D5F1}
:root[data-accent="emerald"]{--accent:#14A085;--accent-hover:#0F8A72;--accent-soft:#E6F4F0;--accent-soft-2:#F0F8F5;--accent-ink:#0C7860;--accent-border:#C8E8DE}
:root[data-accent="violet"]{--accent:#6F58D9;--accent-hover:#5C46C2;--accent-soft:#ECE8F9;--accent-soft-2:#F4F1FB;--accent-ink:#4F3CB0;--accent-border:#D5CCF1}

body{
  font-family:var(--font-ui);font-size:var(--t-body);
  font-weight:400;line-height:1.5;color:var(--ink-1);
  -webkit-font-smoothing:antialiased;
  text-rendering:optimizeLegibility;
  background:var(--canvas);overflow:hidden;
}

@@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
@@keyframes spin{to{transform:rotate(360deg)}}
@@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
@@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}

/* ══════════════════════════════════════
   SCREENS
══════════════════════════════════════ */
.screen{position:fixed;inset:0;z-index:80;display:flex;flex-direction:column;background:var(--canvas);overflow:hidden;animation:fadeIn .25s ease}
.screen.hidden{display:none!important}

/* ── LOGIN ── */
#screen-login{
  align-items:center;justify-content:center;
  background:linear-gradient(145deg,#FFF8F8 0%,#F3F0FF 55%,#EFF8FF 100%);
}
.login-card{
  background:var(--surface);
  border:1px solid var(--line-1);
  border-radius:16px;
  padding:52px 60px 44px;
  text-align:center;
  width:420px;
  box-shadow:var(--shadow-lg),0 0 0 1px rgba(0,0,0,.02);
  animation:slideUp .35s ease;
}
.login-logo{
  width:60px;height:60px;border-radius:14px;
  background:var(--accent);color:#fff;
  font-size:26px;font-weight:700;letter-spacing:-.02em;
  display:flex;align-items:center;justify-content:center;
  margin:0 auto var(--s5);
}
.login-title{
  font-family:var(--font-display);font-size:26px;font-weight:700;
  color:var(--ink-0);letter-spacing:-.02em;margin-bottom:var(--s2);
}
.login-sub{
  font-size:var(--t-small);color:var(--ink-3);line-height:1.6;
  margin-bottom:var(--s7);
}
.btn-google{
  display:flex;align-items:center;justify-content:center;gap:var(--s3);
  width:100%;padding:11px var(--s6);
  border-radius:var(--r-md);border:1px solid var(--line-1);
  background:var(--surface);font-size:var(--t-small);font-weight:600;
  color:var(--ink-0);cursor:pointer;
  transition:background var(--tr),border-color var(--tr),box-shadow var(--tr);
  box-shadow:var(--shadow-sm);
}
.btn-google:hover{background:var(--surface-hover);border-color:var(--line-3);box-shadow:var(--shadow-md)}
.g-icon{width:18px;height:18px;flex-shrink:0}
.login-footer{font-size:var(--t-micro);color:var(--ink-4);margin-top:var(--s5);line-height:1.55}

/* ── HOME ── */
#screen-home{background:var(--canvas)}
.h-topbar{
  height:var(--topbar-h);background:var(--surface);
  border-bottom:1px solid var(--line-1);
  display:flex;align-items:center;padding:0 var(--s6);gap:var(--s3);
  flex-shrink:0;
}
.h-bmark{
  width:28px;height:28px;border-radius:var(--r-md);
  background:var(--accent);color:#fff;font-size:13px;font-weight:700;
  display:flex;align-items:center;justify-content:center;
}
.h-bname{font-size:15px;font-weight:700;color:var(--ink-0);letter-spacing:-.01em}
.h-user{margin-left:auto;display:flex;align-items:center;gap:var(--s3)}
.h-email{font-size:var(--t-small);color:var(--ink-3)}
.h-av{
  width:30px;height:30px;border-radius:50%;
  background:var(--accent);color:#fff;font-size:11px;font-weight:700;
  display:flex;align-items:center;justify-content:center;cursor:pointer;
  transition:background var(--tr);
}
.h-av:hover{background:var(--accent-hover)}

.h-body{flex:1;overflow-y:auto;padding:var(--s8) var(--s8)}
.h-hdr{margin-bottom:var(--s7)}
.h-eyebrow{font-size:var(--t-micro);font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);margin-bottom:var(--s2)}
.h-title{font-family:var(--font-display);font-size:28px;font-weight:700;color:var(--ink-0);letter-spacing:-.02em;line-height:1.2;margin-bottom:var(--s2)}
.h-sub{font-size:var(--t-body);color:var(--ink-3)}

.prog-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:var(--s5);max-width:720px}
.prog-tile{
  background:var(--surface);border:1px solid var(--line-1);border-radius:var(--r-lg);
  padding:var(--pad-card);cursor:pointer;
  transition:border-color var(--tr),box-shadow var(--tr),transform var(--tr);
  position:relative;overflow:hidden;animation:fadeIn .3s ease;
}
.prog-tile::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--accent);opacity:.5}
.prog-tile:hover{border-color:var(--accent-border);box-shadow:var(--shadow-md);transform:translateY(-1px)}
.prog-tile:hover::before{opacity:1}
.prog-tile.inactive{cursor:default;opacity:.55}
.prog-tile.inactive::before{background:var(--ink-5)}
.prog-tile:hover.inactive{transform:none;box-shadow:none;border-color:var(--line-1)}
.prog-ico{
  width:40px;height:40px;border-radius:var(--r-md);
  background:var(--accent-soft);color:var(--accent-ink);
  display:flex;align-items:center;justify-content:center;margin-bottom:var(--s4);
}
.prog-tile.inactive .prog-ico{background:var(--surface-soft);color:var(--ink-3)}
.prog-name{font-size:var(--t-h3);font-weight:700;color:var(--ink-0);letter-spacing:-.01em;margin-bottom:var(--s2)}
.prog-desc{font-size:var(--t-small);color:var(--ink-3);line-height:1.6;margin-bottom:var(--s5)}
.prog-foot{display:flex;align-items:center;justify-content:space-between}
.prog-badge{
  font-size:var(--t-micro);font-weight:600;padding:3px 10px;
  border-radius:var(--r-pill);letter-spacing:.02em;
}
.prog-badge.active{background:var(--affirm-soft);color:var(--affirm-ink)}
.prog-badge.soon{background:var(--surface-soft);color:var(--ink-3)}
.prog-arrow{color:var(--accent)}

/* ══════════════════════════════════════
   APP WORKSPACE
══════════════════════════════════════ */
.app{display:flex;height:100vh;overflow:hidden;background:var(--canvas)}

/* Sidebar */
.sidebar{
  width:var(--rail-w);min-width:var(--rail-w);
  display:flex;flex-direction:column;
  background:var(--canvas);border-right:1px solid var(--line-1);
  overflow:hidden;position:relative;z-index:20;flex-shrink:0;
  transition:width var(--tr),min-width var(--tr);
}
.sidebar.col{width:60px;min-width:60px}
.sb-top{
  height:var(--topbar-h);display:flex;align-items:center;
  padding:0 var(--s5);gap:var(--s3);
  border-bottom:1px solid var(--line-1);flex-shrink:0;
}
.bmark{
  width:28px;height:28px;border-radius:var(--r-md);
  background:var(--accent);color:#fff;font-size:13px;font-weight:700;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:background var(--tr);flex-shrink:0;
}
.bmark:hover{background:var(--accent-hover)}
.bname{font-size:15px;font-weight:700;letter-spacing:-.01em;color:var(--ink-0);white-space:nowrap;cursor:pointer;transition:opacity var(--tr)}
.sidebar.col .bname{opacity:0;pointer-events:none}

.sb-prog{padding:var(--s4) var(--s3) var(--s3);flex-shrink:0;border-bottom:1px solid var(--line-1)}
.sb-prog-btn{
  display:flex;align-items:center;gap:var(--s3);width:100%;
  padding:8px var(--s3);border-radius:var(--r-md);transition:background var(--tr);overflow:hidden;
}
.sb-prog-btn:hover{background:var(--surface-hover)}
.sb-prog-ico{
  width:22px;height:22px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  background:var(--accent-soft);color:var(--accent-ink);border-radius:var(--r-sm);font-size:11px;
}
.sb-prog-lbl{flex:1;font-size:var(--t-small);font-weight:500;color:var(--ink-0);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;transition:opacity var(--tr);text-align:left}
.sidebar.col .sb-prog-lbl{opacity:0}

.nav-list{flex:1;padding:var(--s3);display:flex;flex-direction:column;gap:2px;overflow-y:auto}
.nv{
  display:flex;align-items:center;gap:var(--s3);
  padding:8px 10px;border-radius:var(--r-md);cursor:pointer;
  transition:background var(--tr),color var(--tr);
  white-space:nowrap;overflow:hidden;
}
.nv:hover{background:var(--surface-hover)}
.nv:hover .ni{color:var(--accent)}
.nv.on{background:var(--accent-soft)}
.nv.on .nl{color:var(--accent-ink);font-weight:600}
.nv.on .ni{color:var(--accent-ink)}
.ni{width:20px;height:20px;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:var(--ink-3);transition:color var(--tr)}
.nl{font-size:var(--t-small);color:var(--ink-1);font-weight:500;transition:opacity var(--tr)}
.sidebar.col .nl{opacity:0}

.sb-bot{padding:var(--s3);border-top:1px solid var(--line-1);flex-shrink:0}
.sb-user{
  display:flex;align-items:center;gap:var(--s3);padding:8px 10px;
  border-radius:var(--r-md);transition:background var(--tr);cursor:pointer;overflow:hidden;
}
.sb-user:hover{background:var(--surface-hover)}
.sb-av{
  width:26px;height:26px;border-radius:50%;background:var(--accent);color:#fff;
  font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.sb-uname{font-size:var(--t-small);color:var(--ink-1);font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;transition:opacity var(--tr)}
.sidebar.col .sb-uname{opacity:0}
.col-btn{
  display:flex;align-items:center;gap:var(--s3);width:100%;padding:8px 10px;
  border-radius:var(--r-md);color:var(--ink-3);transition:background var(--tr),color var(--tr);
  white-space:nowrap;overflow:hidden;margin-bottom:4px;
}
.col-btn:hover{background:var(--surface-hover);color:var(--ink-1)}
.col-ico{width:20px;height:20px;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.col-lbl{font-size:var(--t-small);transition:opacity var(--tr)}
.sidebar.col .col-lbl{opacity:0}

[data-tip]{position:relative}
.sidebar.col [data-tip]:hover::after{
  content:attr(data-tip);
  position:absolute;left:calc(100% + 10px);top:50%;transform:translateY(-50%);
  background:var(--ink-0);color:#fff;font-size:var(--t-micro);font-weight:500;
  padding:5px 10px;border-radius:var(--r-sm);white-space:nowrap;pointer-events:none;z-index:200;
}

/* Main */
.main{flex:1;display:flex;flex-direction:column;min-width:0;overflow:hidden;background:var(--canvas)}

/* Topbar */
.topbar{
  height:var(--topbar-h);display:flex;align-items:center;gap:var(--s5);
  padding:0 var(--s6);background:var(--surface);border-bottom:1px solid var(--line-1);
  flex-shrink:0;z-index:19;
}
.breadcrumb{display:flex;align-items:center;gap:var(--s2);font-size:var(--t-small);color:var(--ink-3);font-weight:500}
.bc-sep{color:var(--ink-4);font-size:11px}
.bc-link{cursor:pointer;transition:color var(--tr)}
.bc-link:hover{color:var(--ink-1)}
.bc-cur{color:var(--ink-0);font-weight:600}
.trr{display:flex;align-items:center;gap:var(--s2);margin-left:auto}
.ibtn{
  width:32px;height:32px;border-radius:var(--r-md);
  display:flex;align-items:center;justify-content:center;
  color:var(--ink-3);transition:background var(--tr),color var(--tr);
}
.ibtn:hover{background:var(--surface-hover);color:var(--ink-1)}
.avbtn{
  width:30px;height:30px;border-radius:50%;background:var(--accent);color:#fff;
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:700;cursor:pointer;transition:background var(--tr);
}
.avbtn:hover{background:var(--accent-hover)}

/* Views */
.view{display:none;flex:1;flex-direction:column;overflow:hidden}
.view.on{display:flex}

/* ── PROGRAM VIEW ── */
.pv-content{flex:1;overflow:hidden;display:flex;flex-direction:column}
.page-hdr{
  padding:var(--s7) var(--s7) 0;background:var(--surface);
  border-bottom:1px solid var(--line-1);flex-shrink:0;
}
.phdr-top{display:flex;align-items:flex-start;justify-content:space-between;gap:var(--s7)}
.phdr-eyebrow{font-size:var(--t-micro);font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);margin-bottom:var(--s2)}
.phdr-title{font-family:var(--font-display);font-size:var(--t-display);font-weight:700;color:var(--ink-0);letter-spacing:-.02em;line-height:1.15;margin-bottom:var(--s2)}
.phdr-sub{font-size:var(--t-h3);color:var(--ink-2);max-width:580px;line-height:1.55;margin-bottom:var(--s5)}
.phdr-right{flex-shrink:0;padding-top:4px}
.status-pill{
  display:inline-flex;align-items:center;gap:7px;
  font-size:var(--t-small);font-weight:500;padding:5px 12px;border-radius:var(--r-pill);
}
.status-pill.conn{background:var(--affirm-soft);color:var(--affirm-ink)}
.status-pill.disc{background:var(--surface-soft);color:var(--ink-3)}
.sp-dot{width:6px;height:6px;border-radius:50%}
.status-pill.conn .sp-dot{background:var(--affirm);animation:pulse 2.4s ease infinite}
.status-pill.disc .sp-dot{background:var(--ink-5)}
.tab-bar{display:flex;align-items:center;padding:0 var(--s7);gap:0;margin-top:var(--s3)}
.tab-btn{
  font-size:var(--t-small);font-weight:500;color:var(--ink-3);
  padding:var(--s3) var(--s2);margin-right:var(--s5);
  border-bottom:2px solid transparent;cursor:pointer;
  transition:color var(--tr),border-color var(--tr);background:none;margin-bottom:-1px;
}
.tab-btn:hover{color:var(--ink-1)}
.tab-btn.on{color:var(--accent);font-weight:600;border-bottom-color:var(--accent)}
.tab-panels{flex:1;overflow:hidden;background:var(--canvas)}
.tab-panel{display:none;height:100%;overflow-y:auto}
.tab-panel.on{display:block}

/* ── INGESTION PANEL ── */
.ingest-panel{padding:var(--s7);max-width:800px}

/* Drive connection card */
.drive-card{
  background:var(--surface);border:1px solid var(--line-1);border-radius:var(--r-lg);
  padding:var(--s5) var(--s6);margin-bottom:var(--s6);
  transition:border-color var(--tr);
}
.drive-card.conn{border-left:3px solid var(--affirm)}
.drive-card.disc{border-left:3px solid var(--ink-5)}
.drive-card-hdr{display:flex;align-items:center;gap:var(--s4)}
.drive-card-ico{
  width:38px;height:38px;border-radius:var(--r-md);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.drive-card-ico.conn{background:var(--affirm-soft);color:var(--affirm-ink)}
.drive-card-ico.disc{background:var(--surface-soft);color:var(--ink-3)}
.drive-card-info{flex:1}
.drive-card-title{font-size:var(--t-h3);font-weight:600;color:var(--ink-0);letter-spacing:-.01em}
.drive-card-email{font-size:var(--t-small);color:var(--ink-3);margin-top:2px}
.drive-card-actions{display:flex;gap:var(--s2);align-items:center;flex-shrink:0}

/* Ingestion form */
.ingest-form{
  background:var(--surface);border:1px solid var(--line-1);border-radius:var(--r-lg);
  padding:var(--s5) var(--s6);margin-bottom:var(--s6);
}
.if-title{font-size:var(--t-h3);font-weight:600;color:var(--ink-0);letter-spacing:-.01em;margin-bottom:var(--s2)}
.if-sub{font-size:var(--t-small);color:var(--ink-3);line-height:1.55;margin-bottom:var(--s5)}
.if-row{display:flex;gap:var(--s3);align-items:center}
.if-input{
  flex:1;background:var(--canvas);border:1px solid var(--line-1);
  border-radius:var(--r-md);padding:9px var(--s4);
  font-size:var(--t-small);color:var(--ink-1);font-family:inherit;outline:none;
  transition:border-color var(--tr),background var(--tr);
}
.if-input::placeholder{color:var(--ink-4)}
.if-input:focus{border-color:var(--accent);background:var(--surface)}

/* Buttons */
.btn-s{
  font-size:var(--t-small);font-weight:500;padding:6px var(--s4);height:32px;
  display:inline-flex;align-items:center;gap:6px;
  border-radius:var(--r-md);background:var(--surface);border:1px solid var(--line-1);
  color:var(--ink-1);transition:background var(--tr),border-color var(--tr);white-space:nowrap;
}
.btn-s:hover{background:var(--surface-hover);border-color:var(--line-3)}
.btn-s.p{background:var(--accent);color:#fff;border-color:var(--accent)}
.btn-s.p:hover{background:var(--accent-hover);border-color:var(--accent-hover)}
.btn-s:disabled{opacity:.45;cursor:not-allowed;pointer-events:none}
.btn-s.danger{color:var(--urgent-ink);border-color:var(--urgent-border)}
.btn-s.danger:hover{background:var(--urgent-soft)}

/* Live log */
.log-card{
  background:var(--surface);border:1px solid var(--line-1);border-radius:var(--r-lg);overflow:hidden;
}
.log-hdr{
  display:flex;align-items:center;gap:var(--s3);
  padding:var(--s4) var(--s5);border-bottom:1px solid var(--line-1);background:var(--surface-soft);
}
.log-hdr-title{font-size:var(--t-small);font-weight:600;color:var(--ink-0)}
.log-status{
  margin-left:auto;display:flex;align-items:center;gap:6px;
  font-size:var(--t-micro);font-weight:600;letter-spacing:.02em;
}
.log-status.idle{color:var(--ink-4)}
.log-status.running{color:var(--caution-ink)}
.log-status.done{color:var(--affirm-ink)}
.log-status.error{color:var(--urgent-ink)}
.ls-dot{width:6px;height:6px;border-radius:50%;background:currentColor}
.log-status.running .ls-dot{animation:pulse 2.4s ease infinite}
.log-body{
  padding:var(--s3) var(--s4);
  min-height:220px;max-height:400px;overflow-y:auto;
  font-family:var(--font-mono);font-size:var(--t-micro);line-height:1.75;
  background:#161B22;color:#C9D1D9;
}
.log-line{display:flex;align-items:flex-start;gap:var(--s3);animation:fadeIn .15s ease}
.log-ts{color:#3D444D;flex-shrink:0;min-width:64px;user-select:none}
.log-msg{flex:1;word-break:break-word}
.log-msg.ok{color:#3FB950}
.log-msg.warn{color:#D29922}
.log-msg.err{color:#F85149}
.log-msg.info{color:#79C0FF}
.log-msg.stage{color:#D2A8FF}
.log-msg.dl{color:#58A6FF}
.log-idle{color:#3D444D;font-style:italic;padding:var(--s2) 0}

/* ── VENDORS TAB ── */
.vendors-panel{padding:var(--s7);overflow-y:auto;height:100%}
.v-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--s5)}
.v-title{font-family:var(--font-display);font-size:var(--t-title);font-weight:700;color:var(--ink-0);letter-spacing:-.02em}
.v-sub{font-size:var(--t-small);color:var(--ink-3);margin-top:var(--s1)}
.vtbl-wrap{background:var(--surface);border:1px solid var(--line-1);border-radius:var(--r-lg);overflow:hidden}
.vtbl{width:100%;border-collapse:collapse}
.vtbl th{font-size:var(--t-micro);font-weight:600;letter-spacing:.05em;color:var(--ink-3);text-transform:uppercase;padding:var(--s4) var(--s5);text-align:left;border-bottom:1px solid var(--line-1);background:var(--surface-soft)}
.vtbl td{font-size:var(--t-small);color:var(--ink-1);padding:var(--s4) var(--s5);border-bottom:1px solid var(--line-2);vertical-align:middle}
.vtbl tr:last-child td{border-bottom:none}
.vtbl tbody tr{cursor:pointer;transition:background var(--tr)}
.vtbl tbody tr:hover td{background:var(--surface-hover)}
.vt-name{font-weight:600;color:var(--ink-0)}
.vt-id{font-family:var(--font-mono);font-size:var(--t-micro);color:var(--ink-4);margin-top:2px}
.score-val{font-family:var(--font-display);font-weight:700;font-size:15px;letter-spacing:-.01em}

/* Badges */
.bdg{display:inline-flex;align-items:center;font-size:var(--t-micro);font-weight:600;letter-spacing:.02em;padding:3px 10px;border-radius:var(--r-pill);line-height:1.55}
.bdg-green{background:var(--affirm-soft);color:var(--affirm-ink)}
.bdg-amber{background:var(--caution-soft);color:var(--caution-ink)}
.bdg-red{background:var(--urgent-soft);color:var(--urgent-ink)}
.bdg-grey{background:var(--surface-soft);color:var(--ink-2)}
.bdg-blue{background:var(--watch-soft);color:var(--watch-ink)}

/* Icons */
.glyph{width:16px;height:16px;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;vertical-align:middle;display:inline-block}
.glyph.sm{width:14px;height:14px}
.glyph.xs{width:12px;height:12px}
.glyph.lg{width:20px;height:20px}

/* Tweaks panel */
.tweaks{
  position:fixed;bottom:var(--s6);right:var(--s6);z-index:500;
  display:none;background:var(--surface);border:1px solid var(--line-1);
  border-radius:var(--r-lg);box-shadow:var(--shadow-lg);min-width:220px;overflow:hidden;
}
.tweaks.open{display:block}
.tw-h{display:flex;align-items:center;justify-content:space-between;padding:var(--s4) var(--s5);border-bottom:1px solid var(--line-1)}
.tw-t{font-size:var(--t-small);font-weight:600;color:var(--ink-0)}
.tw-x{color:var(--ink-3);cursor:pointer;display:flex}
.tw-b{padding:var(--s3) var(--s5) var(--s5)}
.tw-sec{margin-bottom:var(--s4)}
.tw-sec:last-child{margin-bottom:0}
.tw-l{font-size:var(--t-micro);font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);margin-bottom:var(--s2)}
.tw-row{display:flex;gap:var(--s1);flex-wrap:wrap}
.tw-swatch{width:22px;height:22px;border-radius:50%;cursor:pointer;transition:transform var(--tr);border:2px solid transparent}
.tw-swatch.on{border-color:var(--ink-0);transform:scale(1.15)}

/* Float tweaks trigger */
.float-settings{
  position:fixed;bottom:var(--s6);right:var(--s6);z-index:50;
  width:40px;height:40px;border-radius:50%;
  background:var(--surface);border:1px solid var(--line-1);
  box-shadow:var(--shadow-md);
  display:flex;align-items:center;justify-content:center;
  color:var(--ink-3);cursor:pointer;
  transition:background var(--tr),color var(--tr),box-shadow var(--tr);
}
.float-settings:hover{background:var(--surface-hover);color:var(--ink-1);box-shadow:var(--shadow-lg)}

.slbl{font-size:var(--t-micro);font-weight:600;letter-spacing:.08em;color:var(--ink-3);text-transform:uppercase;margin-bottom:var(--s4)}
</style>
</head>
<body>

