@page "/connect"
@{
    Layout = null;
}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Kozmo · Connect Data</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{min-height:100%;font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;-webkit-font-smoothing:antialiased;background:#F8FAFE}
a{color:inherit;text-decoration:none}
button{font:inherit;cursor:pointer;border:0;background:transparent;color:inherit;padding:0}

@@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
@@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

/* ══════════════════ PAGE ══════════════════ */
.page{
  min-height:100vh;
  background:linear-gradient(160deg,#F0F4FF 0%,#FAF7FF 40%,#F0F9FF 100%);
  display:flex;flex-direction:column;
}
.page-body{
  flex:1;
  max-width:860px;width:100%;
  margin:0 auto;padding:52px 40px 120px;
}

/* Header */
.pg-eyebrow{
  font-size:10.5px;font-weight:700;letter-spacing:.12em;
  text-transform:uppercase;color:#0D9488;margin-bottom:14px;
  animation:fadeUp .3s ease both;
}
.pg-title{
  font-size:32px;font-weight:700;color:#111827;
  letter-spacing:-.025em;line-height:1.2;margin-bottom:12px;
  animation:fadeUp .3s ease .05s both;
}
.pg-sub{
  font-size:14px;color:#6B7280;line-height:1.65;max-width:520px;
  margin-bottom:36px;
  animation:fadeUp .3s ease .1s both;
}
.pg-sub strong{font-weight:600;color:#374151}

/* Tab bar */
.tab-bar{
  display:flex;align-items:center;gap:2px;
  border-bottom:1px solid #E5E7EB;margin-bottom:28px;
  animation:fadeUp .3s ease .15s both;
}
.tbar-btn{
  display:flex;align-items:center;gap:7px;
  font-size:13px;font-weight:500;color:#6B7280;
  padding:10px 14px;border-bottom:2px solid transparent;
  transition:color .12s,border-color .12s;cursor:pointer;
  white-space:nowrap;margin-bottom:-1px;
}
.tbar-btn:hover{color:#374151}
.tbar-btn.on{color:#111827;font-weight:600;border-bottom-color:#4F46E5}
.tbar-count{
  font-size:11px;font-weight:600;padding:1px 7px;
  background:#F3F4F6;color:#6B7280;border-radius:999px;
}
.tbar-btn.on .tbar-count{background:#EEF2FF;color:#4F46E5}

/* Connector grid */
.conn-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:14px;
  margin-bottom:20px;
  animation:fadeUp .3s ease .2s both;
}
.conn-card{
  background:#FFFFFF;border:1px solid #E5E7EB;border-radius:10px;
  padding:18px 20px;transition:border-color .12s,box-shadow .12s;
}
.conn-card:hover{border-color:#D1D5DB;box-shadow:0 2px 8px rgba(0,0,0,.06)}
.conn-card.connected{
  border:1.5px solid #A7F3D0;background:#F0FDF4;
}
.conn-card.connected:hover{border-color:#6EE7B7;box-shadow:0 2px 8px rgba(16,185,129,.1)}

/* Card header row */
.cc-hdr{display:flex;align-items:flex-start;gap:12px;margin-bottom:12px}
.cc-logo{
  width:36px;height:36px;border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-size:13px;font-weight:700;color:#FFFFFF;
  flex-shrink:0;letter-spacing:-.01em;
}
.cc-info{flex:1;min-width:0}
.cc-name{font-size:14px;font-weight:600;color:#111827;margin-bottom:2px;line-height:1.3}
.cc-type{font-size:12px;color:#9CA3AF}

/* Status */
.cc-status{
  display:flex;align-items:center;gap:6px;
  font-size:12px;margin-bottom:8px;
}
.cc-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.cc-dot.green{background:#10B981;animation:pulse 2.5s ease infinite}
.cc-dot.gray{background:#D1D5DB}
.cc-status-text{color:#6B7280}
.cc-status-text.connected{color:#059669;font-weight:500}
.cc-scope{font-size:11px;color:#9CA3AF;font-family:ui-monospace,"Cascadia Code",monospace}

/* Connect link */
.cc-connect{
  font-size:12px;font-weight:600;color:#4573D2;
  display:inline-flex;align-items:center;gap:4px;
}
.cc-connect:hover{color:#3730A3;text-decoration:underline}

/* Disclaimer */
.disclaimer{
  font-size:11.5px;color:#9CA3AF;margin-bottom:32px;
  display:flex;align-items:flex-start;gap:7px;
  animation:fadeUp .3s ease .25s both;
}
.disc-ico{flex-shrink:0;margin-top:1px}

/* Stats bar */
.stats-bar{
  display:grid;grid-template-columns:repeat(4,1fr);gap:0;
  background:#FFFFFF;border:1px solid #E5E7EB;border-radius:10px;
  overflow:hidden;margin-bottom:0;
  animation:fadeUp .3s ease .3s both;
}
.stat-col{
  padding:18px 20px;border-right:1px solid #E5E7EB;
}
.stat-col:last-child{border-right:none}
.stat-lbl{
  font-size:10.5px;font-weight:600;letter-spacing:.08em;
  text-transform:uppercase;color:#9CA3AF;margin-bottom:8px;
}
.stat-val{font-size:26px;font-weight:700;color:#111827;letter-spacing:-.02em;line-height:1}
.stat-sub{font-size:11.5px;color:#9CA3AF;margin-top:4px}

/* Footer */
.page-footer{
  position:fixed;bottom:0;left:0;right:0;
  background:#FFFFFF;border-top:1px solid #E5E7EB;
  padding:14px 40px;
  display:flex;align-items:center;justify-content:space-between;
  z-index:100;
}
.footer-info{font-size:12.5px;color:#9CA3AF}
.footer-info span{color:#6B7280;font-weight:500}
.footer-nav{display:flex;align-items:center;gap:12px}
.btn-back{
  font-size:13px;font-weight:500;color:#6B7280;padding:8px 18px;
  border-radius:8px;border:1px solid #E5E7EB;
  transition:background .12s,border-color .12s;
}
.btn-back:hover{background:#F9FAFB;border-color:#D1D5DB}
.btn-next{
  display:inline-flex;align-items:center;gap:8px;
  background:#312E81;color:#FFFFFF;
  padding:10px 22px;border-radius:8px;
  font-size:13px;font-weight:600;
  transition:background .12s;
}
.btn-next:hover{background:#1E1B4B}
.btn-next:disabled,.btn-next.disabled{
  background:#9CA3AF;cursor:not-allowed;pointer-events:none;
}
</style>
</head>
<body>
<div class="page">
  <div class="page-body">

    <p class="pg-eyebrow">Connect Data</p>
    <h1 class="pg-title">Bring in your commercial world.</h1>
    <p class="pg-sub">
      Connect contracts, vendors, and the systems they live in. Kozmo&rsquo;s
      <strong>Intake Agent</strong> begins parsing as soon as a source comes
      online &mdash; you don&rsquo;t need to wait for everything.
    </p>

    <!-- Tab bar -->
    <div class="tab-bar">
      <button class="tbar-btn on" type="button">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Connectors <span class="tbar-count" id="tc-signals">13</span>
      </button>
      <button class="tbar-btn" type="button">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        Local files &amp; folders <span class="tbar-count">0</span>
      </button>
    </div>

    <!-- Connector grid — Google Drive first (connected) -->
    <div class="conn-grid" id="conn-grid">

      <!-- Google Drive — connection state set by JS -->
      <div class="conn-card" id="drive-card">
        <div class="cc-hdr">
          <div class="cc-logo" style="background:transparent;padding:0;width:38px;height:38px">
            <svg width="36" height="32" viewBox="0 0 87 78" aria-hidden="true">
              <path d="M6.1 66l4.1 7.1c.9 1.5 2.1 2.7 3.5 3.6L27.5 53H0c0 1.7.4 3.4 1.3 4.9L6.1 66z" fill="#0066DA"/>
              <path d="M43.5 25L29.7 1.3C28.3 2.2 27 3.4 26.1 4.9L1.3 48.1c-.8 1.5-1.3 3.1-1.3 4.9h27.5L43.5 25z" fill="#00AC47"/>
              <path d="M73.3 76.7c1.5-.9 2.7-2.1 3.5-3.6l1.7-2.9 8.2-14.2c.8-1.5 1.3-3.2 1.3-4.9H60.5L73.3 76.7z" fill="#EA4335"/>
              <path d="M43.5 25l13.8-23.7C55.8.4 54.1 0 52.3 0H34.7c-1.8 0-3.5.4-5 1.3L43.5 25z" fill="#00832D"/>
              <path d="M60.5 53H27.5L13.7 76.7c1.5.8 3.2 1.3 5 1.3h47.6c1.8 0 3.5-.4 5-1.3L60.5 53z" fill="#2684FC"/>
              <path d="M73.1 25.5L59.9 2.9C59 1.4 57.8.2 56.3.4L43.5 25 60.5 53h27.4c0-1.7-.4-3.4-1.3-4.9L73.1 25.5z" fill="#FFBA00"/>
            </svg>
          </div>
          <div class="cc-info">
            <div class="cc-name">Google Drive</div>
            <div class="cc-type">Cloud storage</div>
          </div>
        </div>
        <div class="cc-status">
          <span class="cc-dot" id="drive-dot"></span>
          <span class="cc-status-text" id="drive-status-text">Checking&hellip;</span>
        </div>
        <div id="drive-scope" class="cc-scope" style="display:none"></div>
        <div id="drive-action"></div>
      </div>

      <!-- SharePoint -->
      <div class="conn-card">
        <div class="cc-hdr">
          <div class="cc-logo" style="background:#0078D4">SH</div>
          <div class="cc-info">
            <div class="cc-name">SharePoint</div>
            <div class="cc-type">Document repository</div>
          </div>
        </div>
        <div class="cc-status">
          <span class="cc-dot gray"></span>
          <span class="cc-status-text">Not connected</span>
        </div>
        <a href="#" class="cc-connect">+ Connect</a>
      </div>

      <!-- Box -->
      <div class="conn-card">
        <div class="cc-hdr">
          <div class="cc-logo" style="background:#0061D5">BO</div>
          <div class="cc-info">
            <div class="cc-name">Box</div>
            <div class="cc-type">Cloud storage</div>
          </div>
        </div>
        <div class="cc-status">
          <span class="cc-dot gray"></span>
          <span class="cc-status-text">Not connected</span>
        </div>
        <a href="#" class="cc-connect">+ Connect</a>
      </div>

      <!-- Dropbox -->
      <div class="conn-card">
        <div class="cc-hdr">
          <div class="cc-logo" style="background:#0061FF">DR</div>
          <div class="cc-info">
            <div class="cc-name">Dropbox</div>
            <div class="cc-type">Cloud storage</div>
          </div>
        </div>
        <div class="cc-status">
          <span class="cc-dot gray"></span>
          <span class="cc-status-text">Not connected</span>
        </div>
        <a href="#" class="cc-connect">+ Connect</a>
      </div>

      <!-- iManage -->
      <div class="conn-card">
        <div class="cc-hdr">
          <div class="cc-logo" style="background:#1B3A5C">IM</div>
          <div class="cc-info">
            <div class="cc-name">iManage</div>
            <div class="cc-type">Legal DMS</div>
          </div>
        </div>
        <div class="cc-status">
          <span class="cc-dot gray"></span>
          <span class="cc-status-text">Not connected</span>
        </div>
        <a href="#" class="cc-connect">+ Connect</a>
      </div>

      <!-- NetDocuments -->
      <div class="conn-card">
        <div class="cc-hdr">
          <div class="cc-logo" style="background:#003A70">NE</div>
          <div class="cc-info">
            <div class="cc-name">NetDocuments</div>
            <div class="cc-type">Legal DMS</div>
          </div>
        </div>
        <div class="cc-status">
          <span class="cc-dot gray"></span>
          <span class="cc-status-text">Not connected</span>
        </div>
        <a href="#" class="cc-connect">+ Connect</a>
      </div>

      <!-- Ironclad -->
      <div class="conn-card">
        <div class="cc-hdr">
          <div class="cc-logo" style="background:#6B3FA0">IR</div>
          <div class="cc-info">
            <div class="cc-name">Ironclad</div>
            <div class="cc-type">Contract platform</div>
          </div>
        </div>
        <div class="cc-status">
          <span class="cc-dot gray"></span>
          <span class="cc-status-text">Not connected</span>
        </div>
        <a href="#" class="cc-connect">+ Connect</a>
      </div>

      <!-- DocuSign CLM -->
      <div class="conn-card">
        <div class="cc-hdr">
          <div class="cc-logo" style="background:#FFCC00;color:#1a1a1a">DC</div>
          <div class="cc-info">
            <div class="cc-name">DocuSign CLM</div>
            <div class="cc-type">Contract platform</div>
          </div>
        </div>
        <div class="cc-status">
          <span class="cc-dot gray"></span>
          <span class="cc-status-text">Not connected</span>
        </div>
        <a href="#" class="cc-connect">+ Connect</a>
      </div>

      <!-- Conga CLM -->
      <div class="conn-card">
        <div class="cc-hdr">
          <div class="cc-logo" style="background:#C0392B">CC</div>
          <div class="cc-info">
            <div class="cc-name">Conga CLM</div>
            <div class="cc-type">Contract platform</div>
          </div>
        </div>
        <div class="cc-status">
          <span class="cc-dot gray"></span>
          <span class="cc-status-text">Not connected</span>
        </div>
        <a href="#" class="cc-connect">+ Connect</a>
      </div>

    </div><!-- /conn-grid -->

    <!-- Disclaimer -->
    <p class="disclaimer">
      <span class="disc-ico">
        <svg width="13" height="13" fill="none" stroke="#9CA3AF" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
      </span>
      All connectors use scoped, read-only OAuth or service principals &middot; review permissions before approval.
    </p>

    <!-- Stats bar removed per request -->

  </div><!-- /page-body -->
</div><!-- /page -->

<!-- Fixed footer -->
<div class="page-footer">
  <span class="footer-info">
    Step 1 &middot; <span id="footer-summary">1 source &middot; 13 signals &middot; 3 vendors</span>
  </span>
  <div class="footer-nav">
    <a href="/" class="btn-back">Back</a>
    <a href="/workspace" class="btn-next" id="btn-continue">
      Continue to mapping &#8594;
    </a>
  </div>
</div>

<script>
(function () {
  'use strict';

  // Check Google Drive auth status and update card
  async function checkDrive() {
    var card   = document.getElementById('drive-card');
    var dot    = document.getElementById('drive-dot');
    var txt    = document.getElementById('drive-status-text');
    var scope  = document.getElementById('drive-scope');
    var action = document.getElementById('drive-action');

    try {
      var r = await fetch('/auth/google/status');
      var d = await r.json();

      if (d.connected && !d.tokenExpired) {
        card.classList.add('connected');
        dot.className  = 'cc-dot green';
        txt.textContent = 'Connected \u00b7 sync ready';
        txt.className   = 'cc-status-text connected';
        if (d.email) {
          scope.textContent = d.email + ' \u00b7 scoped read-only';
          scope.style.display = 'block';
          scope.style.marginBottom = '4px';
        }
        action.innerHTML = '';
        // Update stats to reflect connected state
        document.getElementById('stat-sources').textContent = '1';
      } else {
        dot.className   = 'cc-dot gray';
        txt.textContent = 'Not connected';
        txt.className   = 'cc-status-text';
        action.innerHTML = '<a href="/auth/google" class="cc-connect">+ Connect Google Drive</a>';
      }
    } catch (e) {
      dot.className   = 'cc-dot gray';
      txt.textContent = 'Status unavailable';
      txt.className   = 'cc-status-text';
      action.innerHTML = '<a href="/auth/google" class="cc-connect">+ Connect Google Drive</a>';
    }
  }

  // Fetch real vendor count from API
  async function loadCounts() {
    try {
      var r    = await fetch('/vendors');
      var list = await r.json();
      var n    = list.length;
      document.getElementById('tc-vendors').textContent   = n;
      document.getElementById('stat-vendors').textContent = n;
      document.getElementById('footer-summary').textContent =
        '1 source \u00b7 13 signals \u00b7 ' + n + ' vendors';
    } catch (e) { /* keep defaults */ }
  }

  checkDrive();
  loadCounts();
})();
</script>
</body>
</html>
