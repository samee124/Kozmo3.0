{
  "config_type": "extraction_schemas",
  "profile": "saas",
  "version": "v1",
  "default": {
    "claim_keys": ["sla_uptime", "csat", "payment_terms", "renewal_date", "annual_value"],
    "metadata_field_groups": []
  },
  "doc_type_schemas": {
    "invoice": {
      "claim_keys": ["sla_uptime", "csat", "payment_terms", "renewal_date", "invoice_amount"],
      "metadata_field_groups": []
    },
    "msa": {
      "claim_keys": ["sla_uptime", "csat", "payment_terms", "renewal_date", "annual_value"],
      "metadata_field_groups": [
        {
          "name": "commercial_terms",
          "fields": ["liability_cap", "term_length", "auto_renewal_terms", "notice_period", "assignment_clause"]
        },
        {
          "name": "risk_legal",
          "fields": ["termination_clause", "indemnification", "governing_law", "dispute_resolution", "force_majeure"]
        },
        {
          "name": "performance_compliance",
          "fields": ["sla_definition", "data_processing_terms", "audit_rights", "warranty_terms"]
        },
        {
          "name": "protective_terms",
          "fields": ["insurance_requirements", "confidentiality", "ip_terms", "non_solicitation"]
        }
      ]
    },
    "order_form": {
      "claim_keys": ["sla_uptime", "csat", "payment_terms", "renewal_date", "annual_value"],
      "metadata_field_groups": []
    },
    "email": {
      "claim_keys": ["payment_terms", "renewal_date", "annual_value", "invoice_amount", "sla_uptime", "support_responsiveness"],
      "metadata_field_groups": [
        {
          "name": "relationship_signals",
          "fields": ["sentiment", "commitment", "issue_raised", "stakeholder_signal", "request"]
        }
      ]
    }
  }
}
